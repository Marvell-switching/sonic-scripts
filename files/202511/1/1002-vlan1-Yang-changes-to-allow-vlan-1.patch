From 1c73894c5552cef7ccbf1172aab4b56b04247061 Mon Sep 17 00:00:00 2001
From: Ravi Minnikanti <rminnikanti@marvell.com>
Date: Mon, 4 May 2026 19:14:44 +0530
Subject: [PATCH] vlan1: Yang changes to allow vlan 1

Signed-off-by: Ravi Minnikanti <rminnikanti@marvell.com>
---
 .../tests/yang_model_tests/tests/vlan.json         |  3 +++
 .../tests/yang_model_tests/tests_config/vlan.json  | 14 ++++++++++++++
 src/sonic-yang-models/yang-models/sonic-vlan.yang  |  4 ++--
 3 files changed, 19 insertions(+), 2 deletions(-)

diff --git a/src/sonic-yang-models/tests/yang_model_tests/tests/vlan.json b/src/sonic-yang-models/tests/yang_model_tests/tests/vlan.json
index 05d8281e6..f05bf6bcc 100644
--- a/src/sonic-yang-models/tests/yang_model_tests/tests/vlan.json
+++ b/src/sonic-yang-models/tests/yang_model_tests/tests/vlan.json
@@ -2,6 +2,9 @@
     "VALID_VLAN": {
         "desc": "Configure VLAN table."
     },
+    "VALID_VLAN1": {
+        "desc": "Configure VLAN 1 (default VLAN)."
+    },
     "VLAN_INTERFACE_IPPREFIX_MUST_CONDITION_FALSE": {
         "desc": "Vlan Interface Ip-prefix must condition failure.",
         "eStrKey" : "Must"
diff --git a/src/sonic-yang-models/tests/yang_model_tests/tests_config/vlan.json b/src/sonic-yang-models/tests/yang_model_tests/tests_config/vlan.json
index e81809119..d3cf97280 100644
--- a/src/sonic-yang-models/tests/yang_model_tests/tests_config/vlan.json
+++ b/src/sonic-yang-models/tests/yang_model_tests/tests_config/vlan.json
@@ -28,6 +28,20 @@
             }
         }
     },
+    "VALID_VLAN1": {
+        "sonic-vlan:sonic-vlan": {
+            "sonic-vlan:VLAN": {
+                "VLAN_LIST": [
+                    {
+                        "admin_status": "up",
+                        "description": "default_vlan",
+                        "mtu": "9100",
+                        "name": "Vlan1"
+                    }
+                ]
+            }
+        }
+    },
     "INCORRECT_VLAN_NAME": {
         "sonic-vlan:sonic-vlan": {
             "sonic-vlan:VLAN": {
diff --git a/src/sonic-yang-models/yang-models/sonic-vlan.yang b/src/sonic-yang-models/yang-models/sonic-vlan.yang
index 7191b962a..ab51cc2c5 100644
--- a/src/sonic-yang-models/yang-models/sonic-vlan.yang
+++ b/src/sonic-yang-models/yang-models/sonic-vlan.yang
@@ -211,12 +211,12 @@ module sonic-vlan {
 
 				leaf name {
 					type string {
-						pattern 'Vlan(409[0-5]|40[0-8][0-9]|[1-3][0-9]{3}|[1-9][0-9]{2}|[1-9][0-9]|[2-9])';
+						pattern 'Vlan(409[0-5]|40[0-8][0-9]|[1-3][0-9]{3}|[1-9][0-9]{2}|[1-9][0-9]|[1-9])';
 					}
 				}
 				leaf vlanid {
 					type uint16 {
-						range 2..4094;
+						range 1..4094;
 					}
 					must "substring-after(../name, 'Vlan') = current()"{
 						error-message "The vlanid must correspond to the VLAN name";
-- 
2.25.1

