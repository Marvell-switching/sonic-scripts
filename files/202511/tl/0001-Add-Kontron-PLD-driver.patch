++static const struct irq_chip kempld_irqchip = {
++	.name			= "kempld-gpio",
++	.irq_mask		= kempld_irq_mask,
++	.irq_unmask		= kempld_irq_unmask,
++	.irq_set_type		= kempld_irq_set_type,
++	.irq_bus_lock		= kempld_bus_lock,
