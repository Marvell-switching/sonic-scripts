+std::string BfdOrch::createStateDBKey(const std::string &key, const std::vector<swss::FieldValueTuple>& data) {
+    // This function converts BFD data from CONFIG_DB to STATE_DB format
+    // CONFIG_DB format: remote_addr|local_addr|interface|hop_type
+    // STATE_DB format: vrf|interface|peer_ip
+    
+    vector<string> key_parts = tokenize(key, '|');
+    
+    string peer_ip = key_parts[0];
+    string interface = key_parts[2];
+    
+    string vrf_name = "default";
+    for (const auto& fv : data) {
+        if (fvField(fv) == "vrf") {
+            vrf_name = fvValue(fv);
+            break;
+        }
+    }
+    
+    return vrf_name + state_db_key_delimiter + interface + state_db_key_delimiter + peer_ip;
+}
