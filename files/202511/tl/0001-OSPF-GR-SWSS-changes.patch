diff --git a/fpmsyncd/ospf_eoiu_marker.py b/fpmsyncd/ospf_eoiu_marker.py
new file mode 100644
index 00000000..cf0e4af5
--- /dev/null
+++ b/fpmsyncd/ospf_eoiu_marker.py
@@ -0,0 +1,184 @@
+#!/usr/bin/env python3
+
+"""
+Description: ospf_eoiu_marker.py -- populating OSPF EOIU marker flag in STATE_DB during warm reboot.
+    The script is started by supervisord in the bgp (routing) docker when the docker is started.
+    It does not do anything if neither system nor bgp warm restart is enabled.
+
+    The script checks OSPF neighbor state via vtysh CLI periodically (every 1 second).
+    It checks whether all OSPF neighbors have reached the "Full" adjacency state
+    using `show ip ospf neighbor json`.
+
+    Once all neighbors are Full (or there are no neighbors), it sets an EOIU flag
+    in STATE_DB at OSPF_STATE_TABLE|IPv4|eoiu.
+
+    fpmsyncd may hold a few seconds (2~5 seconds) after getting the flag before
+    starting routing reconciliation. This should be enough for all routes to be
+    synced to fpmsyncd from ospf via zebra/FPM. If not, the system is probably
+    already in a wrong state.
+
+    For any reason the script fails to set the EOIU flag in STATE_DB,
+    the warm_restart ospf_timer will kick in later as a safety net.
+
+Note: OSPFv2 is IPv4-only, so only OSPF_STATE_TABLE|IPv4|eoiu is used.
+    Future OSPFv3 support should use a separate OSPF6_STATE_TABLE.
+"""
+
+import sys
+import time
+import syslog
+import subprocess
+import traceback
+import json
+from swsscommon import swsscommon
+from time import gmtime, strftime
+
+THIS_MODULE = "ospf_eoiu_marker"
+
+
+class OspfStateCheck():
+    # Timeout the check process in 120 seconds if not finished.
+    # Consistent with the default timeout for routing warm restart in fpmsyncd.
+    DEF_TIME_OUT = 120
+
+    # Check OSPF neighbor state every 1 second
+    CHECK_INTERVAL = 1
+
+    def __init__(self):
+        self.ospf_eoiu = False
+
+    def set_ospf_eoiu_marker(self, state):
+        """Write OSPF_STATE_TABLE|IPv4|eoiu in STATE_DB."""
+        db = swsscommon.SonicV2Connector(host='127.0.0.1')
+        db.connect(db.STATE_DB, False)
+        key = "OSPF_STATE_TABLE|IPv4|eoiu"
+        db.set(db.STATE_DB, key, 'state', state)
+        timestamp = strftime("%Y-%m-%d %H:%M:%S", gmtime())
+        db.set(db.STATE_DB, key, 'timestamp', timestamp)
+        db.close(db.STATE_DB)
+
+    def clean_ospf_eoiu_marker(self):
+        """Delete OSPF_STATE_TABLE|IPv4|eoiu from STATE_DB."""
+        db = swsscommon.SonicV2Connector(host='127.0.0.1')
+        db.connect(db.STATE_DB, False)
+        db.delete(db.STATE_DB, "OSPF_STATE_TABLE|IPv4|eoiu")
+        db.close(db.STATE_DB)
+        syslog.syslog('Cleaned OSPF IPv4 eoiu marker flag')
+
+    def check_ospf_neighbors_full(self):
+        """
+        Check if all OSPF neighbors are in Full state.
+
+        Returns:
+            True  - all neighbors are Full, or there are no neighbors
+            False - some neighbors are not yet Full, or ospfd is not reachable
+            None  - error occurred (vtysh unreachable, JSON parse failure)
+        """
+        try:
+            cmd = "vtysh -c 'show ip ospf neighbor json'"
+            output = subprocess.getoutput(cmd)
+            neighbor_info = json.loads(output)
+
+            # The JSON output has a top-level "neighbors" dict.
+            # Each key is a neighbor router-id mapping to a list of
+            # adjacencies (one per interface).
+            # Each adjacency has a "converged" field: "Full", "Init", etc.
+            #
+            # If there are no neighbors: {"neighbors": {}} or just {}
+            neighbors = neighbor_info.get("neighbors", {})
+
+            if not neighbors:
+                syslog.syslog('OSPF has no neighbors, marking EOIU reached')
+                return True
+
+            for router_id, adjacencies in neighbors.items():
+                for adj in adjacencies:
+                    converged = adj.get("converged", "")
+                    if converged != "Full":
+                        syslog.syslog(syslog.LOG_DEBUG,
+                                      'OSPF neighbor {} not Full yet (state: {})'.format(
+                                          router_id, converged))
+                        return False
+
+            syslog.syslog('All OSPF neighbors are Full')
+            return True
+
+        except Exception:
+            syslog.syslog(syslog.LOG_ERR,
+                          "*ERROR* check_ospf_neighbors_full Exception: %s" %
+                          (traceback.format_exc()))
+            return None
+
+    def wait_for_ospf_eoiu(self):
+        """
+        Poll OSPF neighbor state until all neighbors are Full or timeout.
+
+        The polling loop runs every CHECK_INTERVAL seconds and times out
+        after DEF_TIME_OUT seconds. If ospfd is not reachable initially
+        (vtysh fails), the loop retries until timeout.
+        """
+        wait_time = self.DEF_TIME_OUT
+        while wait_time >= 0:
+            result = self.check_ospf_neighbors_full()
+            if result is True:
+                self.ospf_eoiu = True
+                syslog.syslog("OSPF IPv4 EOIU reached")
+                break
+
+            time.sleep(self.CHECK_INTERVAL)
+            wait_time -= self.CHECK_INTERVAL
+
+        if not self.ospf_eoiu:
+            syslog.syslog(syslog.LOG_ERR,
+                          "OSPF IPv4 EOIU not reached within {} seconds".format(
+                              self.DEF_TIME_OUT))
+
+
+def main():
+    print("ospf_eoiu_marker service is started")
+
+    try:
+        ospf_state_check = OspfStateCheck()
+    except Exception as e:
+        syslog.syslog(syslog.LOG_ERR,
+                      "{}: error exit 1, reason {}".format(THIS_MODULE, str(e)))
+        sys.exit(1)
+
+    # Always clean the eoiu marker in STATE_DB first
+    ospf_state_check.clean_ospf_eoiu_marker()
+
+    # Use warmstart python binding to check warmstart information
+    warmstart = swsscommon.WarmStart()
+    # app_name="ospf": fpmsyncd initializes WARM_RESTART_TABLE|ospf restore_count=0
+    # on every boot (when protocol=ospf), so checkWarmStart will find the entry
+    # and not fall back to cold start.
+    # docker_name="bgp": the OSPF marker runs inside the bgp (routing) container.
+    # incr_restore_cnt=False: the marker only reads warm restart state, it does
+    # not own the restore_count lifecycle (fpmsyncd does via WarmStartHelper).
+    warmstart.initialize("ospf", "bgp")
+    warmstart.checkWarmStart("ospf", "bgp", False)
+
+    # If neither bgp nor system warm reboot is enabled, don't run
+    if not warmstart.isWarmStart():
+        syslog.syslog("ospf_eoiu_marker service is skipped as warm restart not enabled")
+        return
+
+    # Set initial EOIU state to unknown
+    ospf_state_check.set_ospf_eoiu_marker("unknown")
+
+    # Poll OSPF neighbor state
+    try:
+        ospf_state_check.wait_for_ospf_eoiu()
+    except Exception as e:
+        syslog.syslog(syslog.LOG_ERR, str(e))
+        sys.exit(1)
+
+    # Set STATE_DB to signal fpmsyncd
+    if ospf_state_check.ospf_eoiu:
+        ospf_state_check.set_ospf_eoiu_marker("reached")
+
+    syslog.syslog("ospf_eoiu_marker service is done")
+
+
+if __name__ == '__main__':
+    main()
