+// Check if eoiu state reached for ipv4 only (OSPFv2).
+static bool ospfEoiuFlagSet(Table &ospfStateTable)
+{
+    string value;
+
+    ospfStateTable.hget("IPv4|eoiu", "state", value);
+    if (value != "reached")
+    {
+        SWSS_LOG_DEBUG("OSPF IPv4|eoiu state: %s", value.c_str());
+        return false;
+    }
+    SWSS_LOG_NOTICE("Warm-Restart ospf eoiu reached for ipv4");
+    return true;
+}
+
