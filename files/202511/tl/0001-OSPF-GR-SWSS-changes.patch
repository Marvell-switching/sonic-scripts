+    Table ospfStateTable(&stateDb, STATE_OSPF_TABLE_NAME);
+
+    /* Initialize WARM_RESTART_TABLE for the active protocol to handle
+     * the first warm boot after a protocol switch. Without this,
+     * WarmStart::checkWarmStart() would find no restore_count and
+     * fall back to cold start. */
+    {
+        Table warmRestartStateTable(&stateDb, STATE_WARM_RESTART_TABLE_NAME);
+        std::string restoreCount;
+        if (!warmRestartStateTable.hget(appName, "restore_count", restoreCount))
+        {
+            warmRestartStateTable.hset(appName, "restore_count", "0");
+            SWSS_LOG_NOTICE("Initialized %s|%s restore_count=0", STATE_WARM_RESTART_TABLE_NAME, appName.c_str());
+        }
+
+        /* Clean up stale state from the inactive protocol's entry.
+         * After switching protocols, the old entry retains state=reconciled
+         * from a previous boot, which is misleading in "show warm_restart state". */
+        std::string inactiveApp = ospfMode ? "bgp" : "ospf";
+        std::string staleState;
+        if (warmRestartStateTable.hget(inactiveApp, "state", staleState))
+        {
+            warmRestartStateTable.hdel(inactiveApp, "state");
+            SWSS_LOG_NOTICE("Cleared stale state '%s' from %s|%s",
+                            staleState.c_str(), STATE_WARM_RESTART_TABLE_NAME, inactiveApp.c_str());
+        }
+    }
 
     NetLink netlink;
 
