+bool VxlanMgr::doVlanMemberStateUpdateTask(const KeyOpFieldsValuesTuple & t)
+{
+    SWSS_LOG_ENTER();
+
+    std::string vlanName = kfvKey(t);
+    std::string memberState;
+
+    // Extract member_state from the update
+    for (auto i : kfvFieldsValues(t))
+    {
+        const std::string & field = fvField(i);
+        const std::string & value = fvValue(i);
+
+        if (field == "member_state")
+        {
+            memberState = value;
+            break;
+        }
+    }
+
+    if (memberState.empty())
+    {
+        // No member_state field, nothing to do
+        return true;
+    }
+
+    // Check if this VLAN has a VNI mapping (is used for EVPN)
+    auto vniMapIt = m_vlanMapCache.find(vlanName);
+    if (vniMapIt == m_vlanMapCache.end())
+    {
+        // VLAN doesn't have VNI mapping, not used for EVPN
+        return true;
+    }
+
+    std::string vni = vniMapIt->second;
+
+    // Find the VNI netdevice name
+    std::string vxlan_dev_name;
+    for (const auto& mapEntry : m_vxlanTunnelMapCache)
+    {
+        if (mapEntry.second.vni_id == vni && mapEntry.second.vlan == vlanName)
+        {
+            vxlan_dev_name = mapEntry.second.vxlan_dev_name;
+            break;
+        }
+    }
+
+    if (vxlan_dev_name.empty())
+    {
+        SWSS_LOG_WARN("VLAN %s has VNI %s but VNI netdevice not found",
+                      vlanName.c_str(), vni.c_str());
+        return true;
+    }
+
+    // Control the VNI netdevice state based on VLAN member state
+    std::string res;
+    int ret;
+    std::string operation;
+
+    if (memberState == "ok")
+    {
+        // Bring UP the VNI netdevice using cmdUpVxlan
+        VxlanInfo info;
+        info.m_vxlan = vxlan_dev_name;
+        ret = cmdUpVxlan(info, res);
+        operation = "UP";
+    }
+    else if (memberState == "notok")
+    {
+        // Bring DOWN the VNI netdevice - this will trigger EVPN route withdrawal
+        ret = downVxlanNetdevice(vxlan_dev_name);
+        operation = "DOWN";
+    }
+    else
+    {
+        // Unknown member_state value, Returns true (success) to avoid retrying for invalid data
+        SWSS_LOG_WARN("Unknown member_state value '%s' for VLAN %s, ignoring",
+                      memberState.c_str(), vlanName.c_str());
+        return true;
+    }
+
+    // Common logging for both UP and DOWN operations
+    if (ret != 0)
+    {
+        SWSS_LOG_WARN("Failed to bring %s VNI netdevice %s (will retry): %s",
+                      operation.c_str(), vxlan_dev_name.c_str(), res.c_str());
+        return false;
+    }
+
+    SWSS_LOG_INFO("Set VNI netdevice %s %s for VLAN %s (VNI %s)",
+                  vxlan_dev_name.c_str(), operation.c_str(), vlanName.c_str(), vni.c_str());
+
+    return true;
+}
