+    def test_VlanMemberStateUpdate(self, dvs):
+        """
+        Test VLAN member state updates in STATE_DB for EVPN VXLAN.
+        Verifies that when the first member is added to a VLAN, member_state is set to 'ok',
+        and when the last member is removed, member_state is set to 'notok'.
+        This ensures proper VNI netdevice state management for EVPN route advertisement/withdrawal.
+        """
+        dvs.setup_db()
+
+        vlan_id = "100"
+        vlan_name = f"Vlan{vlan_id}"
+        interface1 = "Ethernet0"
+        interface2 = "Ethernet4"
+
+        # Create VLAN
+        self.dvs_vlan.create_vlan(vlan_id)
+        vlan_oid = self.dvs_vlan.get_and_verify_vlan_ids(1)[0]
+        self.dvs_vlan.verify_vlan(vlan_oid, vlan_id)
+
+        # Verify STATE_DB entry exists but has no member_state (initial state)
+        state_db = dvs.get_state_db()
+        vlan_state = state_db.get_entry("VLAN_TABLE", vlan_name)
+        assert "member_state" not in vlan_state or vlan_state.get("member_state") == "", \
+            f"Expected no member_state after VLAN creation, got {vlan_state.get('member_state')}"
+
+        # Add first member - should trigger member_state = 'ok' in STATE_DB
+        self.dvs_vlan.create_vlan_member(vlan_id, interface1)
+        self.dvs_vlan.verify_vlan_member(vlan_oid, interface1)
+
+        # Verify STATE_DB entry has member_state = 'ok'
+        state_db = dvs.get_state_db()
+        vlan_state = state_db.get_entry("VLAN_TABLE", vlan_name)
+        assert vlan_state.get("member_state") == "ok", \
+            f"Expected member_state='ok' after adding first member, got {vlan_state.get('member_state')}"
+
+        # Add second member - member_state should remain 'ok' (no duplicate writes)
+        self.dvs_vlan.create_vlan_member(vlan_id, interface2)
+        self.dvs_vlan.verify_vlan_member(vlan_oid, interface2)
+
+        # Verify STATE_DB still has member_state = 'ok'
+        vlan_state = state_db.get_entry("VLAN_TABLE", vlan_name)
+        assert vlan_state.get("member_state") == "ok", \
+            f"Expected member_state='ok' after adding second member, got {vlan_state.get('member_state')}"
+
+        # Remove first member - member_state should remain 'ok' (still has one member)
+        self.dvs_vlan.remove_vlan_member(vlan_id, interface1)
+        time.sleep(1)
+
+        vlan_state = state_db.get_entry("VLAN_TABLE", vlan_name)
+        assert vlan_state.get("member_state") == "ok", \
+            f"Expected member_state='ok' after removing first member (one member remains), got {vlan_state.get('member_state')}"
+
+        # Remove last member - should trigger member_state = 'notok' in STATE_DB
+        self.dvs_vlan.remove_vlan_member(vlan_id, interface2)
+        self.dvs_vlan.get_and_verify_vlan_member_ids(0)
+        time.sleep(1)
+
+        # Verify STATE_DB entry has member_state = 'notok'
+        vlan_state = state_db.get_entry("VLAN_TABLE", vlan_name)
+        assert vlan_state.get("member_state") == "notok", \
+            f"Expected member_state='notok' after removing last member, got {vlan_state.get('member_state')}"
+
+        # Tear down / Clean up
+        self.dvs_vlan.remove_vlan(vlan_id)
+        self.dvs_vlan.get_and_verify_vlan_ids(0)
+
+        # Verify STATE_DB entry is removed after VLAN deletion
+        vlan_state = state_db.get_entry("VLAN_TABLE", vlan_name)
+        assert vlan_state == {}, \
+            f"Expected empty STATE_DB entry after VLAN deletion, got {vlan_state}"
+
 
