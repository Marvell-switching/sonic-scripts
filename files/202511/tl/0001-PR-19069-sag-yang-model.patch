diff --git a/src/sonic-yang-models/yang-models/sonic-static-anycast-gateway.yang b/src/sonic-yang-models/yang-models/sonic-static-anycast-gateway.yang
new file mode 100644
index 000000000..5c5e153ff
--- /dev/null
+++ b/src/sonic-yang-models/yang-models/sonic-static-anycast-gateway.yang
@@ -0,0 +1,30 @@
+module sonic-static-anycast-gateway {
+
+    yang-version 1.1;
+
+    namespace "http://github.com/sonic-net/sonic-static-anycast-gateway";
+    prefix sag;
+
+    import ietf-yang-types {
+        prefix yang;
+    }
+
+    description "SAG yang Module for SONiC OS";
+
+    revision 2025-04-22 {
+        description
+            "Initial version";
+    }
+
+    container sonic-static-anycast-gateway {
+        container SAG {
+            container GLOBAL {
+                description "Global static anycast gateway configuration";
+
+                leaf gateway_mac {
+                    type yang:mac-address;
+                }
+            }
+        }
+    }
+}
