+@warm_restart.command('protocol')
+@click.argument('protocol', metavar='<protocol>', required=True, type=click.Choice(["bgp", "ospf"]))
+@click.pass_context
+def warm_restart_protocol(ctx, protocol):
+    """Set warm restart protocol for routing (bgp or ospf)"""
+    db = ValidatedConfigDBConnector(ctx.obj['db'])
+    try:
+        if protocol == 'ospf':
+            metadata = ctx.obj['db'].get_entry('DEVICE_METADATA', 'localhost')
+            if metadata.get('frr_mgmt_framework_config') != 'true':
+                ctx.fail("OSPF GR requires frr_mgmt_framework_config to be enabled in DEVICE_METADATA")
+        entry = ctx.obj['db'].get_entry('WARM_RESTART', 'bgp')
+        cleared_fields = []
+
+        if protocol == 'ospf':
+            for field in ['bgp_eoiu', 'bgp_timer']:
+                if field in entry:
+                    cleared_fields.append(field)
+        elif protocol == 'bgp':
+            for field in ['ospf_eoiu', 'ospf_timer']:
+                if field in entry:
+                    cleared_fields.append(field)
+
+        if cleared_fields:
+            for field in cleared_fields:
+                del entry[field]
+            entry['warm_restart_protocol'] = protocol
+            # Delete and recreate: mod_entry can't remove individual fields,
+            # so we delete the whole entry and write back without the cleared fields.
+            db.mod_entry('WARM_RESTART', 'bgp', None)
+            db.mod_entry('WARM_RESTART', 'bgp', entry)
+            click.echo("Note: cleared {} (not applicable when protocol={})".format(
+                ', '.join(cleared_fields), protocol))
+        else:
+            db.mod_entry('WARM_RESTART', 'bgp', {'warm_restart_protocol': protocol})
+    except ValueError as e:
+        ctx.fail("Invalid ConfigDB. Error: {}".format(e))
+
+@warm_restart.command('ospf_timer')
+@click.argument('seconds', metavar='<seconds>', required=True, type=int)
+@click.pass_context
+def warm_restart_ospf_timer(ctx, seconds):
+    """Set OSPF warm restart timer duration in seconds"""
+    db = ValidatedConfigDBConnector(ctx.obj['db'])
+    metadata = ctx.obj['db'].get_entry('DEVICE_METADATA', 'localhost')
+    if metadata.get('frr_mgmt_framework_config') != 'true':
+        ctx.fail("OSPF GR requires frr_mgmt_framework_config to be enabled in DEVICE_METADATA")
+    if ADHOC_VALIDATION:
+        if seconds not in range(1, 3600):
+            ctx.fail("ospf warm restart timer must be in range 1-3600")
+    try:
+        entry = ctx.obj['db'].get_entry('WARM_RESTART', 'bgp')
+        if entry.get('warm_restart_protocol', 'bgp') != 'ospf':
+            click.echo("Warning: warm_restart_protocol is not set to 'ospf'; ospf_timer is saved but will not take effect until protocol is switched to 'ospf'")
+        db.mod_entry('WARM_RESTART', 'bgp', {'ospf_timer': seconds})
+    except ValueError as e:
+        ctx.fail("Invalid ConfigDB. Error: {}".format(e))
+
+@warm_restart.command('ospf_eoiu')
+@click.argument('enable', metavar='<enable>', default='true', required=False, type=click.Choice(["true", "false"]))
+@click.pass_context
+def warm_restart_ospf_eoiu(ctx, enable):
+    """Enable or disable OSPF EOIU during warm restart"""
+    db = ValidatedConfigDBConnector(ctx.obj['db'])
+    metadata = ctx.obj['db'].get_entry('DEVICE_METADATA', 'localhost')
+    if metadata.get('frr_mgmt_framework_config') != 'true':
+        ctx.fail("OSPF GR requires frr_mgmt_framework_config to be enabled in DEVICE_METADATA")
+    try:
+        entry = ctx.obj['db'].get_entry('WARM_RESTART', 'bgp')
+        if entry.get('warm_restart_protocol', 'bgp') != 'ospf':
+            click.echo("Warning: warm_restart_protocol is not set to 'ospf'; ospf_eoiu is saved but will not take effect until protocol is switched to 'ospf'")
+        db.mod_entry('WARM_RESTART', 'bgp', {'ospf_eoiu': enable})
+    except ValueError as e:
+        ctx.fail("Invalid ConfigDB. Error: {}".format(e))
+
 def vrf_add_management_vrf(config_db):
     """Enable management vrf in config DB"""
 
