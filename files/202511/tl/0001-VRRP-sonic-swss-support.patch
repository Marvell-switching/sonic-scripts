+VrrpMgr::VrrpMgr(DBConnector *cfgDb, DBConnector *appDb, DBConnector *stateDb, const std::vector<std::string> &tableNames) : 
+        Orch(cfgDb, tableNames),
+        m_appPortTable(appDb, APP_PORT_TABLE_NAME),
