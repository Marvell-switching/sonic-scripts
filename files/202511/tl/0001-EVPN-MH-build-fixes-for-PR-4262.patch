diff --git a/fdbsyncd/fdbsync.cpp b/fdbsyncd/fdbsync.cpp
index 3b984df2..03266004 100644
--- a/fdbsyncd/fdbsync.cpp
+++ b/fdbsyncd/fdbsync.cpp
@@ -902,6 +902,17 @@ void FdbSync::onMsgNbr(int nlmsg_type, struct nl_object *obj, struct nlmsghdr *h
         }
     }
 
+    /* Drop MH peer sync entries that have no VTEP or NHG destination */
+    if (tb[NDA_FLAGS_EXT] && nlmsg_type == RTM_NEWNEIGH && dest_type == UNKNOWN)
+    {
+        uint32_t ext_flags = *(uint32_t *)RTA_DATA(tb[NDA_FLAGS_EXT]);
+        if (ext_flags & NTF_EXT_MH_PEER_SYNC)
+        {
+            SWSS_LOG_INFO("Dropping MH peer sync entry with no VTEP/NHG");
+            return;
+        }
+    }
+
     ifindex = rtnl_neigh_get_ifindex(neigh);
     if (m_intf_info.find(ifindex) != m_intf_info.end())
     {
@@ -969,11 +980,23 @@ void FdbSync::onMsgNbr(int nlmsg_type, struct nl_object *obj, struct nlmsghdr *h
             SWSS_LOG_INFO("Remote VTEP MAC sent without NDA_DST attribute");
             return;
         }
-        else
+
+        /* Validate the VTEP address from the raw NDA_DST attribute.
+         * If dst is 0.0.0.0 (e.g. MH peer sync with no remote VTEP),
+         * drop the entry. */
+        if (tb[NDA_DST] && RTA_PAYLOAD(tb[NDA_DST]) == sizeof(struct in_addr))
         {
-            SWSS_LOG_INFO("Tunnel IP %s", nl_addr2str(vtep_addr, buf, sizeof(buf)));
-            dest_type = VTEP;
+            struct in_addr dst_v4;
+            memcpy(&dst_v4, RTA_DATA(tb[NDA_DST]), sizeof(dst_v4));
+            if (dst_v4.s_addr == 0)
+            {
+                SWSS_LOG_INFO("Remote VTEP MAC sent with zero NDA_DST, dropping");
+                return;
+            }
         }
+
+        SWSS_LOG_INFO("Tunnel IP %s", nl_addr2str(vtep_addr, buf, sizeof(buf)));
+        dest_type = VTEP;
     }
 
     if (state & NUD_NOARP)
