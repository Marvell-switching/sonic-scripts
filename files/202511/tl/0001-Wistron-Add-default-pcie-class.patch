From 5728f956ece7d572f5aa6e5f6ad866c179d09cb4 Mon Sep 17 00:00:00 2001
From: Pavan Naregundi <pnaregundi@marvell.com>
Date: Wed, 11 Mar 2026 14:44:33 +0530
Subject: [PATCH] [Wistron] Add default pcie class

Signed-off-by: Pavan Naregundi <pnaregundi@marvell.com>
---
 .../6512-32r/sonic_platform/pcie.py                 | 13 +++++++++++++
 1 file changed, 13 insertions(+)
 create mode 100644 platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/pcie.py

diff --git a/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/pcie.py b/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/pcie.py
new file mode 100644
index 000000000..d4843ed1e
--- /dev/null
+++ b/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/pcie.py
@@ -0,0 +1,13 @@
+#!/usr/bin/env python3
+
+try:
+    from sonic_platform_base.sonic_pcie.pcie_common import PcieUtil
+except ImportError as e:
+    raise ImportError(str(e) + "- required module not found") from e
+
+
+class Pcie(PcieUtil):
+    """Platform-specific Pcie class"""
+
+    def __init__(self, platform_path):
+        PcieUtil.__init__(self, platform_path)
-- 
2.25.1

