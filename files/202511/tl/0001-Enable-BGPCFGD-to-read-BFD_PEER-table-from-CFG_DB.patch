 src/sonic-bgpcfgd/tests/test_bfdmgr.py        | 12 +--
 src/sonic-bgpcfgd/tests/test_static_rt_bfd.py | 60 +++++++-------
 4 files changed, 98 insertions(+), 62 deletions(-)

