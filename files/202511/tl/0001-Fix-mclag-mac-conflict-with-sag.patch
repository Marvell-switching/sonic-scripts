+        fvs = dvs.get_app_db().wait_for_entry(swsscommon.APP_SAG_TABLE_NAME, "GLOBAL")
+        self.check_app_db_sag_mac(fvs, sag_mac)
+
+        self.enable_sag(vlan)
+
+        # Step 2: Verify SAG MAC is applied
+        fvs = self.app_db.wait_for_field_match(
+            swsscommon.APP_INTF_TABLE_NAME,
+            vlan_intf,
+            {"mac_addr": sag_mac})
+        self.check_app_db_intf(fvs, sag_mac, "true")
+        self.check_kernel_intf_mac(dvs, vlan_intf, sag_mac)
+
+        # Step 3: Set mac_addr in CONFIG_DB of the VLAN_INTERFACE
+        self.cfg_db.update_entry(swsscommon.CFG_VLAN_INTF_TABLE_NAME, vlan_intf, {"mac_addr": config_mac})
+        time.sleep(2)
+
+        # Step 4: Verify mac_addr in INTF_TABLE is still SAG mac
+        fvs = self.app_db.get_entry(swsscommon.APP_INTF_TABLE_NAME, vlan_intf)
+        assert fvs.get("mac_addr") == sag_mac, f"Expected SAG MAC {sag_mac}, got {fvs.get('mac_addr')}"
+        self.check_kernel_intf_mac(dvs, vlan_intf, sag_mac)
+
+        # Step 5: Set MCLAG_INTF_TABLE mac_addr
+        mclag_tbl = swsscommon.Table(self.pdb, "MCLAG_INTF_TABLE")
+        fvs = swsscommon.FieldValuePairs([("mac_addr", mclag_mac)])
+        mclag_tbl.set(vlan_intf, fvs)
+        time.sleep(2)
+
+        # Verify MCLAG_INTF_TABLE entry was created
+        (exists, mclag_fvs_pairs) = mclag_tbl.get(vlan_intf)
+        assert exists, f"MCLAG_INTF_TABLE entry not found for {vlan_intf}"
+        mclag_fvs = dict(mclag_fvs_pairs)
+        assert mclag_fvs.get("mac_addr") == mclag_mac, f"Expected MCLAG MAC {mclag_mac}, got {mclag_fvs.get('mac_addr')}"
+
+        # Verify that mac_addr in INTF_TABLE is still SAG mac
+        fvs = self.app_db.get_entry(swsscommon.APP_INTF_TABLE_NAME, vlan_intf)
+        assert fvs.get("mac_addr") == sag_mac, f"Expected SAG MAC {sag_mac}, got {fvs.get('mac_addr')}"
+        self.check_kernel_intf_mac(dvs, vlan_intf, sag_mac)
+
+        # Step 6: Disable SAG on the interface
+        self.disable_sag(vlan)
+
+        # Step 7: Verify MCLAG_INTF_TABLE mac is applied
+        # When SAG is disabled, next priority is: MCLAG
+        fvs = self.app_db.wait_for_field_match(
+            swsscommon.APP_INTF_TABLE_NAME,
+            vlan_intf,
+            {"mac_addr": mclag_mac})
+        assert fvs.get("mac_addr") == mclag_mac, f"Expected MCLAG MAC {mclag_mac}, got {fvs.get('mac_addr')}"
+        self.check_kernel_intf_mac(dvs, vlan_intf, mclag_mac)
+
+        # Step 8: Remove MCLAG_INTF_TABLE from APP_DB
+        mclag_tbl._del(vlan_intf)
+        time.sleep(2)
+
+        # Step 9: Verify that mac_addr in CONFIG_DB is applied in INTF_TABLE
+        fvs = self.app_db.wait_for_field_match(
+            swsscommon.APP_INTF_TABLE_NAME,
+            vlan_intf,
+            {"mac_addr": config_mac})
+        assert fvs.get("mac_addr") == config_mac, f"Expected Config MAC {config_mac}, got {fvs.get('mac_addr')}"
+        self.check_kernel_intf_mac(dvs, vlan_intf, config_mac)
+
+        # Step 10: Remove mac_addr in CONFIG_DB
+        self.cfg_db.update_entry(swsscommon.CFG_VLAN_INTF_TABLE_NAME, vlan_intf, {"mac_addr": ""})
+        time.sleep(2)
+
+        # Verify system_mac is applied in INTF_TABLE
+        fvs = self.app_db.wait_for_field_match(
+            swsscommon.APP_INTF_TABLE_NAME,
+            vlan_intf,
+            {"mac_addr": system_mac})
+        assert fvs.get("mac_addr") == system_mac, f"Expected System MAC {system_mac}, got {fvs.get('mac_addr')}"
+        self.check_kernel_intf_mac(dvs, vlan_intf, system_mac)
+
+        # Cleanup: delete SAG global MAC address
+        self.remove_sag_mac()
+        self.app_db.wait_for_deleted_entry(swsscommon.APP_SAG_TABLE_NAME, "GLOBAL")
+
+        # remove ip
+        dvs.remove_ip_address(vlan_intf, ip)
+
+        # reset interface
+        self.reset_interface(dvs, interface, vlan)
