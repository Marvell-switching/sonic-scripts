+
+bool IntfMgr::doMclagIntfTask(const vector<string>& keys,
+        const vector<FieldValueTuple> &data,
+        const string& op)
+{
+    SWSS_LOG_ENTER();
+
+    string alias = keys[0];
+    string mclagMac = "";
+    string macToApply = "";  // MAC to apply and update to DB
+
+    // Extract MAC address from the data
+    for (auto idx : data)
+    {
+        const auto &field = fvField(idx);
+        const auto &value = fvValue(idx);
+
+        if (field == "mac_addr")
+        {
+            mclagMac = value;
+            break;
+        }
+    }
+
+    if (op == SET_COMMAND)
+    {
+        if (mclagMac.empty())
+        {
+            SWSS_LOG_WARN("MCLAG_INTF_TABLE SET for %s with empty MAC", alias.c_str());
+            return true;
+        }
+
+        // Store the MCLAG MAC for this interface
+        m_mclagIntfMacMap[alias] = mclagMac;
+        SWSS_LOG_NOTICE("MCLAG_INTF_TABLE: Stored MCLAG MAC %s for interface %s", 
+            mclagMac.c_str(), alias.c_str());
+
+        // Check if SAG is enabled for this interface
+        // SAG takes priority over MCLAG MAC
+        auto sagIt = m_sagIntfList.find(alias);
+        if (sagIt != m_sagIntfList.end() && sagIt->second == true)
+        {
+            SWSS_LOG_NOTICE("MCLAG_INTF_TABLE: Interface %s has SAG enabled, restoring SAG MAC (iccpd may have changed it)", 
+                alias.c_str());
+            // iccpd has already modified the kernel MAC to MCLAG MAC
+            // We must restore SAG MAC since it has higher priority
+            string sagMac = gSagMacAddress.to_string();
+            setIntfMacAndState(alias, sagMac);
+            macToApply = sagMac;
+        }
+        else
+        {
+            // Apply MCLAG MAC when SAG is not active
+            setIntfMacAndState(alias, mclagMac);
+            macToApply = mclagMac;
+        }
+    }
+    else if (op == DEL_COMMAND)
+    {
+        // Remove MCLAG MAC for this interface
+        auto it = m_mclagIntfMacMap.find(alias);
+        if (it != m_mclagIntfMacMap.end())
+        {
+            SWSS_LOG_NOTICE("MCLAG_INTF_TABLE: Removed MCLAG MAC for interface %s", alias.c_str());
+            m_mclagIntfMacMap.erase(it);
+            
+            // Restore MAC based on priority: SAG > Config MAC > Global MAC
+            auto sagIt = m_sagIntfList.find(alias);
+            if (sagIt != m_sagIntfList.end() && sagIt->second == true)
+            {
+                SWSS_LOG_INFO("MCLAG_INTF_TABLE: Interface %s has SAG enabled, SAG MAC already applied", 
+                    alias.c_str());
+                // SAG MAC is already active, no need to change
+            }
+            else
+            {
+                // Determine which MAC to restore
+                auto macIt = m_macSetIntfMap.find(alias);
+                
+                if (macIt != m_macSetIntfMap.end())
+                {
+                    // Restore config MAC
+                    macToApply = macIt->second;
+                    SWSS_LOG_INFO("MCLAG_INTF_TABLE: Restoring interface %s to config MAC %s", 
+                        alias.c_str(), macToApply.c_str());
+                }
+                else
+                {
+                    // No SAG, no CONFIG_DB MAC - restore to global MAC
+                    macToApply = gMacAddress.to_string();
+                    SWSS_LOG_INFO("MCLAG_INTF_TABLE: Restoring interface %s to global MAC", 
+                        alias.c_str());
+                }
+                
+                setIntfMacAndState(alias, macToApply);
+            }
+        }
+    }
+
+    if (!macToApply.empty())
+    {
+        vector<FieldValueTuple> fvVector;
+        FieldValueTuple macTuple("mac_addr", macToApply);
+        fvVector.push_back(macTuple);
+        m_appIntfTableProducer.set(alias, fvVector);
+    }
+
+    return true;
 }
 
