From ffe8992041a6d395008abd82c4e56d55f2e1f83b Mon Sep 17 00:00:00 2001
From: Parthiv Shah <parthiv@marvell.com>
Date: Thu, 19 Mar 2026 16:28:00 +0530
Subject: [PATCH] Fix EEPROM read crash on database exception

Update sonic-cfggen calls in chassis.py to read from config_db.json
file instead of querying the running database, ensuring
hwsku and platform metadata are available before database services
are up. Remove the read_eeprom_db() early-return path in eeprom.py
so EEPROM data is always read from the hardware/cache rather than
the database.

Signed-off-by: Parthiv Shah <parthiv@marvell.com>
---
 .../6512-32r/sonic_platform/chassis.py          | 17 +++--------------
 .../6512-32r/sonic_platform/eeprom.py           |  9 ---------
 2 files changed, 3 insertions(+), 23 deletions(-)

diff --git a/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/chassis.py b/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/chassis.py
index d27b26b98..221d6a955 100755
--- a/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/chassis.py
+++ b/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/chassis.py
@@ -11,6 +11,7 @@ try:
     import time
     import subprocess
     from sonic_platform_base.chassis_base import ChassisBase
+    from sonic_py_common import device_info
 except ImportError as e:
     raise ImportError(str(e) + "- required module not found")
 
@@ -25,8 +26,6 @@ PMON_REBOOT_CAUSE_PATH = "/usr/share/sonic/platform/api_files/reboot-cause/"
 REBOOT_CAUSE_FILE = "reboot-cause.txt"
 PREV_REBOOT_CAUSE_FILE = "previous-reboot-cause.txt"
 HOST_CHK_CMD = ["docker"]
-GET_HWSKU_CMD = ["sonic-cfggen", "-d", "-v", "DEVICE_METADATA.localhost.hwsku"]
-GET_PLATFORM_CMD = ["sonic-cfggen", "-d", "-v", "DEVICE_METADATA.localhost.platform"]
 EEPROM_BOOT_TIME_INIT_DONE='/tmp/eeprom_init_done'
 
 class Chassis(ChassisBase):
@@ -36,8 +35,8 @@ class Chassis(ChassisBase):
         super(Chassis, self).__init__()
 
         # Initialize SKU name and Platform name
-        self.sku_name = self._get_sku_name()
-        self.platform_name = self._get_platform_name()
+        (self.platform_name, self.sku_name) = device_info.get_platform_and_hwsku()
+
         self.name = self.sku_name
 
         self._transceiver_presence = [0] * NUM_SFP
@@ -150,16 +149,6 @@ class Chassis(ChassisBase):
 
         return (reboot_cause, description)
 
-    def _get_sku_name(self):
-        p = subprocess.Popen(GET_HWSKU_CMD, stdout=subprocess.PIPE)
-        out, err = p.communicate()
-        return out.decode().rstrip('\n')
-
-    def _get_platform_name(self):
-        p = subprocess.Popen(GET_PLATFORM_CMD, stdout=subprocess.PIPE)
-        out, err = p.communicate()
-        return out.decode().rstrip('\n')
-
     def get_watchdog(self):
         """
         Retreives hardware watchdog device on this chassis
diff --git a/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/eeprom.py b/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/eeprom.py
index 7db38ead6..87a790f1c 100755
--- a/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/eeprom.py
+++ b/platform/marvell-teralynx/sonic-platform-modules-wistron/6512-32r/sonic_platform/eeprom.py
@@ -61,15 +61,6 @@ class Tlv(eeprom_tlvinfo.TlvInfoDecoder):
     def _load_eeprom(self):
         original_stdout = sys.stdout
         sys.stdout = StringIO()
-        err = self.read_eeprom_db()
-        if err:
-            # Failed to read EEPROM information from database. Read from cache file
-            pass
-        else:
-            decode_output = sys.stdout.getvalue()
-            sys.stdout = original_stdout
-            return self.__parse_output(decode_output)
-
         status = self.check_status()
         if status < 'ok':
             return False
-- 
2.25.1

