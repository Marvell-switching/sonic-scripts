+pair<sai_object_id_t, sai_object_id_t> L2NhgOrch::createSaiNextHop(sai_object_id_t l2_nhg_id,
+                                                                   sai_object_id_t tunnel_oid,
+                                                                   const string& remote_vtep_ip)
