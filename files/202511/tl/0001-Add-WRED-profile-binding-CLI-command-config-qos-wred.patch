+#!/usr/bin/env python3
+"""
+Test cases for WRED profile binding functionality in config qos wred-profile command.
+
+This test module validates:
+1. Queue specification parsing (single, range, comma-separated, mixed)
+2. WRED profile binding to interfaces and queues
+3. WRED profile unbinding from queues
+4. Show qos wred-profile CLI (filters, empty table, invalid queue_spec)
+5. Validation of profile and interface existence
+6. Error handling and edge cases
+
+QUEUE table keys in mocks match ConfigDBConnector multi-key form: a 2-tuple
+(port_name, queue_index_as_str), e.g. ('Ethernet0', '1'). Bind/unbind tests
+assert set_entry/get_entry use the same tuple keys as production code.
+"""
+
+import os
+import unittest
+from unittest import mock
+
+from click.testing import CliRunner
+
+# Click maps ctx.fail() to exit 1 or 2 depending on version / CliRunner behavior.
+_FAIL_EXIT_CODES = (1, 2)
+
+# Mock the utilities before importing
+os.environ["UTILITIES_UNIT_TESTING"] = "2"
+os.environ["UTILITIES_UNIT_TESTING_TOPOLOGY"] = "single_asic"
+
+# Import from config package properly
+import config.main as config  # noqa: E402
+import show.main as show  # noqa: E402
+from config.main import parse_queue_range, validate_wred_profile_exists, validate_interface_exists  # noqa: E402
+
+
+class TestQueueRangeParser(unittest.TestCase):
+    """Test queue range parsing functionality"""
+
+    def test_parse_single_queue(self):
+        """Test parsing single queue index"""
+        valid, invalid = parse_queue_range("3")
+        self.assertEqual(valid, [3])
+        self.assertEqual(invalid, [])
+
+    def test_parse_queue_range(self):
+        """Test parsing queue range"""
+        valid, invalid = parse_queue_range("1-4")
+        self.assertEqual(valid, [1, 2, 3, 4])
+        self.assertEqual(invalid, [])
+
+    def test_parse_comma_separated_queues(self):
+        """Test parsing comma-separated queues"""
+        valid, invalid = parse_queue_range("1,3,5")
+        self.assertEqual(valid, [1, 3, 5])
+        self.assertEqual(invalid, [])
+
+    def test_parse_mixed_queues(self):
+        """Test parsing mixed ranges and comma-separated values"""
+        valid, invalid = parse_queue_range("0-2,5,7-9")
+        self.assertEqual(valid, [0, 1, 2, 5, 7, 8, 9])
+        self.assertEqual(invalid, [])
+
+    def test_parse_invalid_range_reversed(self):
+        """Test parsing invalid range (end < start)"""
+        valid, invalid = parse_queue_range("5-1")
+        self.assertEqual(valid, [])
+        self.assertIn("5-1", invalid)
+
+    def test_parse_invalid_queue_index(self):
+        """Test parsing invalid queue index"""
+        valid, invalid = parse_queue_range("256")  # > 255
+        self.assertEqual(valid, [])
+        self.assertIn("256", invalid)
+
+    def test_parse_invalid_negative_queue(self):
+        """Test parsing negative queue index"""
+        valid, invalid = parse_queue_range("-1")
+        self.assertEqual(valid, [])
+        self.assertIn("-1", invalid)
+
+    def test_parse_invalid_text(self):
+        """Test parsing non-numeric text"""
+        valid, invalid = parse_queue_range("abc")
+        self.assertEqual(valid, [])
+        self.assertIn("abc", invalid)
+
+    def test_parse_duplicate_removal(self):
+        """Test that duplicate queue indices are removed"""
+        valid, invalid = parse_queue_range("1,1,2,2,3")
+        self.assertEqual(valid, [1, 2, 3])
+        self.assertEqual(invalid, [])
+
+    def test_parse_whitespace_handling(self):
+        """Test handling of whitespace in queue specs"""
+        valid, invalid = parse_queue_range(" 1 - 3 , 5 ")
+        self.assertEqual(valid, [1, 2, 3, 5])
+        self.assertEqual(invalid, [])
+
+    def test_parse_max_queue_index(self):
+        """Test parsing maximum valid queue index"""
+        valid, invalid = parse_queue_range("255")
+        self.assertEqual(valid, [255])
+        self.assertEqual(invalid, [])
+
+    def test_parse_range_to_max(self):
+        """Test parsing range to maximum queue index"""
+        valid, invalid = parse_queue_range("250-255")
+        self.assertEqual(valid, [250, 251, 252, 253, 254, 255])
+        self.assertEqual(invalid, [])
+
+
+class TestWREDProfileValidation(unittest.TestCase):
+    """Test WRED profile and interface validation"""
+
+    def setUp(self):
+        """Set up test fixtures"""
+        self.mock_config_db = mock.MagicMock()
+
+    def test_validate_profile_exists(self):
+        """Test validating existing WRED profile"""
+        self.mock_config_db.get_table.return_value = {
+            'AZURE_LOSSLESS': {'green_min_threshold': '1048576'},
+            'TEST_PROFILE': {'green_min_threshold': '2097152'}
+        }
+        result = validate_wred_profile_exists(self.mock_config_db, 'AZURE_LOSSLESS')
+        self.assertTrue(result)
+
+    def test_validate_profile_not_exists(self):
+        """Test validating non-existent WRED profile"""
+        self.mock_config_db.get_table.return_value = {
+            'AZURE_LOSSLESS': {'green_min_threshold': '1048576'}
+        }
+        result = validate_wred_profile_exists(self.mock_config_db, 'NONEXISTENT')
+        self.assertFalse(result)
+
+    def test_validate_interface_exists(self):
+        """Test validating existing interface"""
+        self.mock_config_db.get_table.return_value = {
+            'Ethernet0': {'mtu': '9100'},
+            'Ethernet4': {'mtu': '9100'}
+        }
+        result = validate_interface_exists(self.mock_config_db, 'Ethernet0')
+        self.assertTrue(result)
+
+    def test_validate_interface_not_exists(self):
+        """Test validating non-existent interface"""
+        self.mock_config_db.get_table.return_value = {
+            'Ethernet0': {'mtu': '9100'}
+        }
+        result = validate_interface_exists(self.mock_config_db, 'Ethernet4')
+        self.assertFalse(result)
+
+
+class TestWREDProfileBindingCLI(unittest.TestCase):
+    """Test WRED profile binding CLI commands.
+
+    QUEUE rows are mocked with 2-tuple keys (interface, queue_index_str) consistent
+    with ConfigDBConnector.get_entry/set_entry, not pipe-joined strings.
+    """
+
+    def setUp(self):
+        """Set up test fixtures"""
+        self.runner = CliRunner()
+        qos_cmd = config.config.commands["qos"]
+        wred_profile_cmd = qos_cmd.commands["wred-profile"]
+        self.bind_cmd = wred_profile_cmd.commands["bind"]
+        self.unbind_cmd = wred_profile_cmd.commands["unbind"]
+
+    @staticmethod
+    def _setup_common_tables(mock_db, profile_exists=True, interface_exists=True):
+        wred_profiles = {
+            'AZURE_LOSSLESS': {'green_min_threshold': '1048576'}
+        } if profile_exists else {}
+        ports = {
+            'Ethernet0': {'mtu': '9100'}
+        } if interface_exists else {}
+
+        mock_db.get_table.side_effect = lambda table: {
+            'WRED_PROFILE': wred_profiles,
+            'PORT': ports
+        }.get(table, {})
+
+    @mock.patch('config.main.ConfigDBConnector')
+    def test_bind_cli_updates_db_and_verbose_output(self, mock_config_db_class):
+        """Test bind command updates DB and emits verbose output"""
+        mock_db = mock.MagicMock()
+        mock_config_db_class.return_value = mock_db
+
+        self._setup_common_tables(mock_db)
+
+        # QUEUE keys: 2-tuples as ConfigDBConnector uses for multi-key tables
+        queue_entries = {
+            ('Ethernet0', '1'): {},
+            ('Ethernet0', '3'): {'wred_profile': 'OLD_PROFILE'},
+        }
+        mock_db.get_entry.side_effect = lambda table, key: dict(queue_entries.get(key, {}))
+
+        result = self.runner.invoke(
+            self.bind_cmd,
+            ['AZURE_LOSSLESS', 'Ethernet0', '1,3', '--verbose']
+        )
+
+        self.assertEqual(result.exit_code, 0)
+        mock_db.connect.assert_called_once()
+        mock_db.get_entry.assert_has_calls([
+            mock.call('QUEUE', ('Ethernet0', '1')),
+            mock.call('QUEUE', ('Ethernet0', '3')),
