+#
+# WRED Profile Binding Helper Functions
+#
+
+def parse_queue_range(queue_spec):
+    """
+    Parse queue specification and return list of valid queue indices.
+
+    Supports formats:
+    - Single: "3" -> [3]
+    - Range: "1-4" -> [1, 2, 3, 4]
+    - Comma-separated: "1,3,5" -> [1, 3, 5]
+    - Mixed: "0-2,5,7-9" -> [0, 1, 2, 5, 7, 8, 9]
+    - Empty segments from repeated or trailing commas are ignored
+
+    Returns tuple: (valid_queues, invalid_queues_info)
+    """
+    valid_queues = []
+    invalid_queues = []
+    MAX_QUEUE_INDEX = 255
+
+    try:
+        # Split by comma for comma-separated values
+        parts = queue_spec.split(',')
+
+        for part in parts:
+            part = part.strip()
+            if not part:
+                continue
+
+            if '-' in part:
+                # Handle range
+                range_parts = part.split('-')
+                if len(range_parts) != 2:
+                    invalid_queues.append(part)
+                    continue
+                try:
+                    start = int(range_parts[0].strip())
+                    end = int(range_parts[1].strip())
+
+                    if start < 0 or end < 0 or start > MAX_QUEUE_INDEX or end > MAX_QUEUE_INDEX:
+                        invalid_queues.append(part)
+                        continue
+
+                    if start > end:
+                        invalid_queues.append(part)
+                        continue
+
+                    for q in range(start, end + 1):
+                        if q not in valid_queues:
+                            valid_queues.append(q)
+                except ValueError:
+                    invalid_queues.append(part)
+            else:
+                # Single queue index
+                try:
+                    queue_idx = int(part.strip())
+                    if queue_idx < 0 or queue_idx > MAX_QUEUE_INDEX:
+                        invalid_queues.append(part)
+                    elif queue_idx not in valid_queues:
+                        valid_queues.append(queue_idx)
+                except ValueError:
+                    invalid_queues.append(part)
+    except Exception as e:
+        click.secho("Error parsing queue specification: {}".format(str(e)), fg="red")
+        return [], [queue_spec]
+
+    valid_queues.sort()
+    return valid_queues, invalid_queues
+
+
+def validate_wred_profile_exists(config_db, profile_name):
+    """Check if WRED profile exists in CONFIG_DB (connector is already namespaced)."""
+    wred_profiles = config_db.get_table('WRED_PROFILE') or {}
+    return profile_name in wred_profiles
+
+
+def validate_interface_exists(config_db, interface_name):
+    """Check if interface exists in PORT table"""
+    ports = config_db.get_table('PORT') or {}
+    return interface_name in ports
+
+
+#
+# 'wred-profile' group ('config qos wred-profile ...')
+#
+
+@qos.group(cls=clicommon.AbbreviationGroup, name='wred-profile')
+@click.pass_context
+def wred_profile(ctx):
+    """WRED profile binding management"""
+    pass
+
+
+@wred_profile.command('bind')
+@click.argument('profile_name', type=str, required=True)
+@click.argument('interface', type=str, required=True)
+@click.argument('queue_spec', type=str, required=True)
+@click.option('--verbose', is_flag=True, help="Enable verbose output")
+@multi_asic_util.multi_asic_click_option_namespace
+@click.pass_context
+def bind_wred_profile(ctx, profile_name, interface, queue_spec, verbose, namespace):
+    """Bind a WRED profile to interface queue(s)
+
+    Examples:
+      config qos wred-profile bind AZURE_LOSSLESS Ethernet0 3
+      config qos wred-profile bind my_profile Ethernet0 1-4
+      config qos wred-profile bind my_profile Ethernet0 1,3,5
+      config qos wred-profile bind my_profile Ethernet0 0-2,5,7-9
+    """
+    log.log_info("'qos wred-profile bind {}' executing...".format(profile_name))
+
+    # Connect to config DB
+    if namespace is None:
+        config_db = ConfigDBConnector()
+    else:
+        config_db = ConfigDBConnector(use_unix_socket_path=True, namespace=namespace)
+
+    config_db.connect()
+
+    # Validate profile exists
+    if not validate_wred_profile_exists(config_db, profile_name):
+        ctx.fail("WRED profile '{}' does not exist".format(profile_name))
+
+    # Validate interface exists
+    if not validate_interface_exists(config_db, interface):
+        ctx.fail("Interface '{}' does not exist".format(interface))
+
+    # Parse queue specification
+    valid_queues, invalid_queues = parse_queue_range(queue_spec)
+
+    if not valid_queues:
+        ctx.fail("No valid queues in specification '{}'".format(queue_spec))
+
+    if invalid_queues:
+        click.secho("Warning: Skipping invalid queue(s): {}".format(', '.join(invalid_queues)), fg="yellow")
+
+    # Bind profile to each valid queue
+    bound_queues = []
+    failed_queues = []
+    for queue_idx in valid_queues:
+        queue_key = (interface, str(queue_idx))
+
+        try:
+            # Get existing queue entry or create new one
+            queue_entry = config_db.get_entry('QUEUE', queue_key)
+            if not queue_entry:
+                queue_entry = {}
+
+            # Set the WRED profile
+            old_profile = queue_entry.get('wred_profile', None)
+            queue_entry['wred_profile'] = profile_name
+
+            # Write back to config DB
+            config_db.set_entry('QUEUE', queue_key, queue_entry)
+            bound_queues.append(queue_idx)
+
+            if verbose:
+                if old_profile:
+                    click.echo("Queue {}|{}: Replaced profile '{}' with '{}'".format(
+                        interface, queue_idx, old_profile, profile_name))
+                else:
+                    click.echo("Queue {}|{}: Bound profile '{}'".format(
+                        interface, queue_idx, profile_name))
+        except Exception as e:
+            click.secho("Error binding queue {}|{}: {}".format(interface, queue_idx, str(e)), fg="red")
+            failed_queues.append(queue_idx)
+
+    if not bound_queues:
+        ctx.fail("Failed to bind profile to any queues")
+
+    if failed_queues:
+        failed_sorted = sorted(set(failed_queues))
+        failed_list = ', '.join(str(q) for q in failed_sorted)
+        click.secho(
+            "Partial success: profile '{}' bound to {} queue(s) on interface {}; "
+            "bind failed for {} queue(s): {}".format(
+                profile_name, len(bound_queues), interface, len(failed_sorted), failed_list),
+            fg="yellow")
+        ctx.fail("WRED profile bind failed for queue(s): {}".format(failed_list))
+
+    click.secho("Successfully bound profile '{}' to {} queue(s) on interface {}".format(
+        profile_name, len(bound_queues), interface), fg="green")
+
+
+@wred_profile.command('unbind')
+@click.argument('interface', type=str, required=True)
+@click.argument('queue_spec', type=str, required=True)
+@click.option('--verbose', is_flag=True, help="Enable verbose output")
+@multi_asic_util.multi_asic_click_option_namespace
+@click.pass_context
+def unbind_wred_profile(ctx, interface, queue_spec, verbose, namespace):
+    """Remove WRED profile binding from interface queue(s)
+
+    Examples:
+      config qos wred-profile unbind Ethernet0 3
+      config qos wred-profile unbind Ethernet0 1-4
+      config qos wred-profile unbind Ethernet0 1,3,5
+    """
+    log.log_info("'qos wred-profile unbind' executing...")
+
+    # Connect to config DB
+    if namespace is None:
+        config_db = ConfigDBConnector()
+    else:
+        config_db = ConfigDBConnector(use_unix_socket_path=True, namespace=namespace)
+
+    config_db.connect()
+
+    # Validate interface exists
+    if not validate_interface_exists(config_db, interface):
+        ctx.fail("Interface '{}' does not exist".format(interface))
+
+    # Parse queue specification
+    valid_queues, invalid_queues = parse_queue_range(queue_spec)
+
+    if not valid_queues:
+        ctx.fail("No valid queues in specification '{}'".format(queue_spec))
+
+    if invalid_queues:
+        click.secho("Warning: Skipping invalid queue(s): {}".format(', '.join(invalid_queues)), fg="yellow")
+
+    # Remove profile binding from each queue
+    unbound_queues = []
+    for queue_idx in valid_queues:
+        queue_key = (interface, str(queue_idx))
+
+        try:
+            queue_entry = config_db.get_entry('QUEUE', queue_key)
+            if queue_entry and 'wred_profile' in queue_entry:
+                old_profile = queue_entry['wred_profile']
+                del queue_entry['wred_profile']
+                if queue_entry:
+                    config_db.set_entry('QUEUE', queue_key, queue_entry)
+                else:
+                    config_db.set_entry('QUEUE', queue_key, None)
+                unbound_queues.append(queue_idx)
+
+                if verbose:
+                    click.echo("Queue {}|{}: Removed profile '{}'".format(
+                        interface, queue_idx, old_profile))
+            elif verbose:
+                click.echo("Queue {}|{}: No WRED profile binding".format(interface, queue_idx))
+        except Exception as e:
+            click.secho("Error unbinding queue {}|{}: {}".format(interface, queue_idx, str(e)), fg="red")
+
+    if unbound_queues:
+        click.secho("Successfully removed WRED profile bindings from {} queue(s) on interface {}".format(
+            len(unbound_queues), interface), fg="green")
+    else:
+        click.secho("No WRED profile bindings were removed", fg="yellow")
+
+
