+# 'wred-profile' subcommand ("show qos wred-profile [interface] [queue_spec]")
+@qos.command('wred-profile')
+@click.argument('interface', type=str, required=False)
+@click.argument('queue_spec', type=str, required=False)
+@multi_asic_util.multi_asic_click_option_namespace
+@click.option('--verbose', is_flag=True, help="Enable verbose output")
+def wred_profile(interface, queue_spec, namespace, verbose):
+    """Show WRED profile bindings for queues
+
+    Examples:
+      show qos wred-profile
+      show qos wred-profile Ethernet0
+      show qos wred-profile Ethernet0 3
+      show qos wred-profile Ethernet0-4              (interface range)
+      show qos wred-profile Ethernet0 0-7          (queue range)
+      show qos wred-profile Ethernet0-5 0-7        (interface and queue range)
+      show qos wred-profile Ethernet0 1,3,5
+      show qos wred-profile Ethernet0 0-2,5,7-9
+    """
+    # Import here to avoid circular imports
+    from config.main import parse_queue_range
+    from utilities_common.intf_filter import interface_in_filter
+
+    # Connect to config DB
+    if namespace is None:
+        config_db = ConfigDBConnector()
+    else:
+        config_db = ConfigDBConnector(use_unix_socket_path=True, namespace=namespace)
+
+    config_db.connect()
+
+    # Get all QUEUE entries
+    queue_table = config_db.get_table('QUEUE')
+
+    if not queue_table:
+        click.echo("No QUEUE entries found in config DB")
+        return
+
+    parsed_queues = None
+    if queue_spec:
+        valid_queues, invalid_queues = parse_queue_range(queue_spec)
+        if invalid_queues and verbose:
+            click.secho("Warning: Skipping invalid queue(s): {}".format(', '.join(invalid_queues)), fg="yellow")
+        parsed_queues = set(valid_queues)
+
+    # Collect bindings
+    bindings = []
+    for queue_key, queue_entry in queue_table.items():
+        if 'wred_profile' not in queue_entry:
+            continue
+
+        # Parse the key: ConfigDB returns tuple (interface, queue_index) for QUEUE table
+        if not (isinstance(queue_key, tuple) and len(queue_key) == 2):
+            continue
+        intf = str(queue_key[0])
+        try:
+            queue_idx_num = int(str(queue_key[1]).strip())
+        except (TypeError, ValueError):
+            continue
+        profile = queue_entry['wred_profile']
+
+        # Filter by interface if specified (supports single or range e.g. Ethernet0-4)
+        if interface and not interface_in_filter(intf, interface):
+            continue
+
+        # Filter by queue_spec if specified (supports single or range e.g. 0-7)
+        if parsed_queues is not None and queue_idx_num not in parsed_queues:
+            continue
+
+        bindings.append((intf, queue_idx_num, profile))
+
+    if not bindings:
+        if interface and queue_spec:
+            click.echo(
+                "No WRED profile bindings found for interface '{}' with queue(s) {}".format(
+                    interface, queue_spec
+                )
+            )
+        elif interface:
+            click.echo("No WRED profile bindings found for interface '{}'".format(interface))
+        else:
+            click.echo("No WRED profile bindings found")
+        return
+
+    # Sort and display
+    bindings.sort()
+
+    # Print header
+    click.echo("\nInterface    Queue  WRED Profile")
+    click.echo("-----------  -----  ------------------------")
+
+    for intf, queue_idx_num, profile in bindings:
+        click.echo("{:<12}  {:<6}  {}".format(intf, queue_idx_num, profile))
+
+    click.echo("\nTotal bindings: {}".format(len(bindings)))
+
