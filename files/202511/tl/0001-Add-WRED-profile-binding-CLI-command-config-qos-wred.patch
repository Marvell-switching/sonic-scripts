+class TestWREDProfileBindingEdgeCases(unittest.TestCase):
+    """Test edge cases and error conditions"""
+
+    def test_parse_empty_string(self):
+        """Test parsing empty queue specification"""
+        valid, invalid = parse_queue_range("")
+        self.assertEqual(valid, [])
+        self.assertEqual(invalid, [])
+
+    def test_parse_trailing_comma(self):
+        """Test parsing queue specification with trailing comma"""
+        valid, invalid = parse_queue_range("1,")
+        self.assertEqual(valid, [1])
+        self.assertEqual(invalid, [])
+
+    def test_parse_malformed_range(self):
+        """Test parsing malformed range"""
+        valid, invalid = parse_queue_range("1-2-3")
+        self.assertEqual(valid, [])
+        self.assertIn("1-2-3", invalid)  # Entire malformed range is marked as invalid
+
+    def test_parse_large_queue_range(self):
+        """Test parsing large queue range"""
+        valid, invalid = parse_queue_range("0-255")
+        self.assertEqual(len(valid), 256)
+        self.assertEqual(valid[0], 0)
+        self.assertEqual(valid[255], 255)
+        self.assertEqual(invalid, [])
+
+    def test_parse_partial_invalid_spec(self):
+        """Test parsing spec with both valid and invalid entries"""
+        valid, invalid = parse_queue_range("0-2,999,5-7")
+        self.assertEqual(valid, [0, 1, 2, 5, 6, 7])
+        self.assertIn("999", invalid)
+
