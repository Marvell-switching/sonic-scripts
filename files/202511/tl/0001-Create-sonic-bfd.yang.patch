--- /dev/null
+++ b/src/sonic-yang-models/yang-models/sonic-bfd.yang
@@ -0,0 +1,194 @@
+module sonic-bfd {
+    yang-version 1.1;
+    namespace "http://github.com/Azure/sonic-bfd";
+    prefix bfd;
+
+    import ietf-yang-types {
+        prefix yang;
+    }
+
+    import ietf-inet-types {
+        prefix inet;
+    }
+
+    import sonic-types {
+        prefix stypes;
+    }
+
+    import sonic-vrf {
+        prefix vrf;
+    }
+
+    organization
+        "SONiC";
+
+    contact
+        "SONiC";
+
+    description
+        "SONIC BFD YANG Module for SONiC OS";
+
+    revision "2025-12-02" {
+        description
+            "Initial revision for BFD YANG model";
+    }
+
+    container sonic-bfd {
+        description
+            "Top-level container for BFD configuration tables.";
+
+        container BFD_PEER {
+            description
+                "BFD peer configuration table.
+                Keys correspond to Config DB entries consumed.";
+
+            list BFD_PEER_LIST {
+                key "remote_addr local_addr interface hop_type";
+
+                leaf remote_addr {
+                    type inet:ip-address;
+                    description
+                        "Remote BFD peer address (IPv4 or IPv6).";
+                }
+
+                leaf local_addr {
+                    type inet:ip-address;
+                    description
+                        "Local BFD address (IPv4 or IPv6).";
+                }
+
+                leaf interface {
+                    type stypes:interface_name;
+                    description
+                        "Interface name for BFD session.";
+                }
+
+                leaf hop_type {
+                    type enumeration {
+                        enum "singlehop" {
+                            description "Single-hop BFD session.";
+                        }
+                        enum "multihop" {
+                            description "Multi-hop BFD session.";
+                        }
+                    }
+                    description
+                        "Hop type for BFD session.";
+                }
+
+                leaf vrf {
+                    type union {
+                        type leafref {
+                            path "/vrf:sonic-vrf/vrf:VRF/vrf:VRF_LIST/vrf:name";
+                        }
+                        type enumeration {
+                            enum "default" {
+                                description "Default VRF (global routing table).";
+                            }
+                        }
+                    }
+                    default "default";
+                    description
+                        "VRF name for this BFD peer.";
+                }
+
+                leaf admin_status {
+                    type enumeration {
+                        enum "up" {
+                            description "BFD session is administratively up.";
+                        }
+                        enum "down" {
+                            description "BFD session is administratively down.";
+                        }
+                    }
+                    default "up";
+                    description
+                        "Administrative status of the BFD peer.";
+                }
+
+                leaf transmit_interval {
+                    type uint32 {
+                        range "10..4294967";
+                    }
+                    description
+                        "Minimum transmit interval in milliseconds.";
+                }
+
+                leaf receive_interval {
+                    type uint32 {
+                        range "10..4294967";
+                    }
+                    description
+                        "Minimum receive interval in milliseconds.";
+                }
+
+                leaf multiplier {
+                    type uint8;
+                    description
+                        "Detection multiplier.";
+                }
+
+                leaf echo_interval {
+                    type uint32 {
+                        range "10..4294967";
+                    }
+                    description
+                        "Echo interval in milliseconds.";
+                }
+
+                leaf echo_mode {
+                    type stypes:boolean_type;
+                    description
+                        "Enable or disable BFD echo mode for this peer.";
+                }
+
+                leaf label {
+                    type string;
+                    description
+                        "Description/label for the BFD peer.";
+                }
+
+                leaf hw_lookup_valid {
+                    type stypes:boolean_type;
+                    description
+                        "Enable or disable hardware lookup for this BFD peer.";
+                    default "false";
+                }
+
+                leaf dst_mac {
+                    type yang:mac-address;
+                    description
+                        "Destination MAC address for BFD packets.";
+                }
+
+                leaf type {
+                    type enumeration {
+                        enum "async_active" {
+                            description "Asynchronous active mode BFD session.";
+                        }
+                        enum "async_passive" {
+                            description "Asynchronous passive mode BFD session.";
+                        }
+                        enum "demand_active" {
+                            description "Demand active mode BFD session.";
+                        }
+                        enum "demand_passive" {
+                            description "Demand passive mode BFD session.";
+                        }
+                    }
+                    default "async_active";
+                    description
+                        "BFD session type.";
+                }
+
+                leaf shutdown_bfd_during_tsa {
+                    type stypes:boolean_type;
+                    description
+                        "Shutdown BFD session when device enters TSA (Traffic Shift Away) state.
+                        If set to true, the BFD session will be removed when TSA is enabled
+                        and recreated when TSA is disabled.";
+                }
+            }
+        }
+    }
+}
