+            else:
+                self.updated_profile_tables[self.multi_asic.current_namespace] = profile_table
+
+    @multi_asic_util.run_on_multi_asic
+    def delete_wred_profile(self, profile):
+        """
+        Delete a WRED profile from ConfigDB.
+
+        Before deletion, checks if the profile is referenced by any QUEUE entries.
+        If dependencies exist, deletion is blocked with an error message listing
+        the dependent queues.
+
+        Args:
+            profile: Profile name to delete
+
+        Raises:
+            Exception if profile doesn't exist or is referenced by queues
+        """
+        chk_exec_privilege()
+
+        # Validate profile name
+        if not self.validate_profile_name(profile):
+            raise Exception("Configuration error. Invalid WRED profile name '%s'. "
+                            "Valid pattern: [a-zA-Z0-9]{1}([-a-zA-Z0-9_]{0,31})" % profile)
+
+        # Check if profile exists
+        existing_profile = self.get_profile_data(profile)
+        if existing_profile is None:
+            raise Exception(f"Configuration error. WRED profile '{profile}' does not exist")
+
+        # Check for queue dependencies
+        queue_table = self.config_db.get_table(QUEUE_TABLE_NAME)
+        dependent_queues = []
+
+        for queue_key, queue_data in queue_table.items():
+            if FIELD in queue_data and queue_data[FIELD] == profile:
+                dependent_queues.append(queue_key)
+
+        if dependent_queues:
+            error_msg = f"Configuration error. Cannot delete WRED profile '{profile}' - it is referenced by the following queues:\n"
+            for queue in dependent_queues:
+                error_msg += f"  {queue}\n"
+            error_msg += "Please remove the profile associations from these queues before deleting the profile."
+            raise Exception(error_msg)
+
+        # Delete the profile from ConfigDB
+        if self.verbose:
+            namespace_str = f" for namespace {self.multi_asic.current_namespace}" if multi_asic.is_multi_asic() else ''
+            print(f"Deleting WRED profile '{profile}'{namespace_str}")
+
+        self.config_db.set_entry(WRED_PROFILE_TABLE_NAME, profile, None)
+
+        # Record the change for unit testing
+        if self.test_filename:
+            profile_table = self.config_db.get_table(WRED_PROFILE_TABLE_NAME)
+            self.updated_profile_tables[self.multi_asic.current_namespace] = profile_table
+
