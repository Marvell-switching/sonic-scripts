+
+        # Check if profile already exists
+        existing_profile = self.get_profile_data(profile)
+        if existing_profile is not None:
+            raise Exception(f"Configuration error. WRED profile '{profile}' already exists")
+
+        # Use only the provided fields - do not add defaults for missing fields
+        profile_entry = profile_data
+
+        # Validate profile data
+        if not self.validate_profile_data(profile_entry):
+            raise Exception("Configuration error. Invalid WRED profile parameters")
+
+        # Create the profile in ConfigDB
+        if self.verbose:
+            namespace_str = f" for namespace {self.multi_asic.current_namespace}" if multi_asic.is_multi_asic() else ''
+            print(f"Creating WRED profile '{profile}'{namespace_str}")
+
+        self.config_db.set_entry(WRED_PROFILE_TABLE_NAME, profile, profile_entry)
+
