+        if os.path.isfile(self._ECNCONFIG_DUMP):
+            os.remove(self._ECNCONFIG_DUMP)
+        super().tearDown()
+
+    def _read_profile_dump(self, profile_name):
+        """Return the stored field dict for *profile_name* from the unit-test dump.
+
+        The dump written by ecnconfig is structured as
+        ``{namespace: {profile_name: {field: value, ...}, ...}, ...}``.
+        For single-ASIC topologies the namespace key is an empty string.
+        """
+        with open(self._ECNCONFIG_DUMP, 'r') as f:
+            data = json.load(f)
+        return data.get('', {}).get(profile_name, {})
