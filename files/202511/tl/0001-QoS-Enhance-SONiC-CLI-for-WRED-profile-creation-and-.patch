+#!/usr/bin/env python3
+"""
+Test cases for WRED profile creation and deletion functionality in ecnconfig.
+
+This test module validates:
+1. Profile creation with various parameter combinations
+2. Profile deletion with dependency checking
+3. ECN mode and enable flag support
+4. Backward compatibility with existing profile modification
+5. Error handling and validation
+"""
+
+import json
+import os
+import unittest
+from unittest import mock
+from click.testing import CliRunner
+
+from .utils import load_source
+
+TEST_ENV_VARS = {
+    "UTILITIES_UNIT_TESTING": "2",
+    "UTILITIES_UNIT_TESTING_TOPOLOGY": "single_asic"
+}
+
+
+def _set_test_env():
+    previous_values = {key: os.environ.get(key) for key in TEST_ENV_VARS}
+    os.environ.update(TEST_ENV_VARS)
+    return previous_values
+
+
+def _restore_env(previous_values):
+    for key, value in previous_values.items():
+        if value is None:
+            os.environ.pop(key, None)
+        else:
+            os.environ[key] = value
+
+
+# Load ecnconfig script via importlib so __spec__, __loader__, and __package__
+# are set correctly, matching the pattern used throughout this test suite.
+test_dir = os.path.dirname(os.path.abspath(__file__))
+script_path = os.path.normpath(os.path.join(test_dir, '..', 'scripts', 'ecnconfig'))
+
+if not os.path.exists(script_path):
+    raise ModuleNotFoundError(f"Could not find ecnconfig script at: {script_path}")
+
