+    def create_wred_profile(self, profile, profile_data):
+        """
+        Create a new WRED profile in ConfigDB.
+
+        Args:
+            profile: Profile name
+            profile_data: Dictionary with profile parameters
+
+        Raises:
+            Exception if profile already exists or validation fails
+        """
