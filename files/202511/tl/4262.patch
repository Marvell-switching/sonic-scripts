+class MockFdbSync : public FdbSync
+{
+public:
+    MockFdbSync(RedisPipeline *m_pipeline, DBConnector *m_stateDb, DBConnector *m_configDb ) : FdbSync(m_pipeline, m_stateDb, m_configDb)
+    {
