+    struct ndmsg *ndm = (struct ndmsg *)NLMSG_DATA(nlmsg);
+    ndm->ndm_state = 0; // Not permanent or no-ARP
+    ndm->ndm_flags = NTF_EXT_LEARNED; // Externally learned
