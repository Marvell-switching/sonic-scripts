+    bool                                using_temp_nhg;
+
+    LabelRouteBulkContext()
+        : excp_intfs_flag(false), using_temp_nhg(false)
+    {
+    }
+
+    // Disable any copy constructors
+    LabelRouteBulkContext(const LabelRouteBulkContext&) = delete;
