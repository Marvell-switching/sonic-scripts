+    memset(grps, 0, sizeof(grps));
+    grps[0].id = 268435458;
+    grps[1].id = 268435459;
+
+    nlmsg = new_nhg_msg(536870913, "", 0, grps, sizeof(grps));
+    m_mockFdbSync.onMsgRaw(nlmsg);
+    free(nlmsg);
