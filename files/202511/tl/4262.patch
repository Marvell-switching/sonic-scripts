+
+            m_FlexCounterOrch = new FlexCounterOrch(m_config_db.get(), flex_counter_tables);
+            gDirectory.set(m_FlexCounterOrch);
+            ut_orch_list.push_back((Orch **)&m_FlexCounterOrch);
