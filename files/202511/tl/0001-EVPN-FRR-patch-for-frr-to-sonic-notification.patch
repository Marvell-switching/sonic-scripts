++
++	return ctx->u.br_port.vlan_cnt;
++}
++
++const vlanid_t *
++dplane_ctx_get_br_port_vlans(const struct zebra_dplane_ctx *ctx)
++{
++	DPLANE_CTX_VALID(ctx);
++
++	return ctx->u.br_port.vlans;
++}
++
+ /* Accessors for PBR iptable information */
+ void dplane_ctx_get_pbr_iptable(const struct zebra_dplane_ctx *ctx,
+ 				struct zebra_pbr_iptable *table)
+@@ -4976,7 +4994,8 @@ done:
+ enum zebra_dplane_result
+ dplane_br_port_update(const struct interface *ifp, bool non_df,
+ 		      uint32_t sph_filter_cnt,
+-		      const struct in_addr *sph_filters, uint32_t backup_nhg_id)
++		      const struct in_addr *sph_filters, uint32_t backup_nhg_id,
++		      uint32_t vlan_cnt, const vlanid_t *vlans)
+ {
+ 	enum zebra_dplane_result result = ZEBRA_DPLANE_REQUEST_FAILURE;
+ 	uint32_t flags = 0;
+@@ -5025,6 +5044,12 @@ dplane_br_port_update(const struct interface *ifp, bool non_df,
+ 	memcpy(ctx->u.br_port.sph_filters, sph_filters,
+ 	       sizeof(ctx->u.br_port.sph_filters[0]) * sph_filter_cnt);
+ 
++	ctx->u.br_port.vlan_cnt = MIN(vlan_cnt, DPLANE_BR_PORT_MAX_VLANS);
++	if (ctx->u.br_port.vlan_cnt)
++		memcpy(ctx->u.br_port.vlans, vlans,
++		       sizeof(ctx->u.br_port.vlans[0])
++			       * ctx->u.br_port.vlan_cnt);
++
+ 	/* Enqueue for processing on the dplane pthread */
+ 	ret = dplane_update_enqueue(ctx);
+ 
+diff --git a/zebra/zebra_dplane.h b/zebra/zebra_dplane.h
+index cabc70c23..4317a1166 100644
+--- a/zebra/zebra_dplane.h
++++ b/zebra/zebra_dplane.h
+@@ -258,6 +258,9 @@ enum dplane_op_e {
+ 
+ #define DPLANE_BR_PORT_NON_DF (1 << 0)
+ 
++/* Max VLANs that can be associated with an ES for BR_PORT_UPDATE */
++#define DPLANE_BR_PORT_MAX_VLANS 256
++
+ /* Definitions for the dplane 'netconf' apis, corresponding to the netlink
+  * NETCONF api.
+  * Sadly, netlink sends incremental updates, so its messages may contain
+@@ -805,6 +808,10 @@ const struct in_addr *
+ dplane_ctx_get_br_port_sph_filters(const struct zebra_dplane_ctx *ctx);
+ uint32_t
+ dplane_ctx_get_br_port_backup_nhg_id(const struct zebra_dplane_ctx *ctx);
++uint32_t
++dplane_ctx_get_br_port_vlan_cnt(const struct zebra_dplane_ctx *ctx);
++const vlanid_t *
++dplane_ctx_get_br_port_vlans(const struct zebra_dplane_ctx *ctx);
+ 
+ /* Accessors for neighbor table information */
+ uint8_t dplane_ctx_neightable_get_family(const struct zebra_dplane_ctx *ctx);
+@@ -879,7 +886,8 @@ enum zebra_dplane_result dplane_route_notif_update(
+  */
+ enum zebra_dplane_result dplane_br_port_update(
+ 	const struct interface *ifp, bool non_df, uint32_t sph_filter_cnt,
+-	const struct in_addr *sph_filters, uint32_t backup_nhg_id);
++	const struct in_addr *sph_filters, uint32_t backup_nhg_id,
++	uint32_t vlan_cnt, const vlanid_t *vlans);
+ 
+ /* Forward ref of nhg_hash_entry */
+ struct nhg_hash_entry;
+diff --git a/zebra/zebra_evpn_mh.c b/zebra/zebra_evpn_mh.c
+index 75e7e2017..1b3b67cfa 100644
+--- a/zebra/zebra_evpn_mh.c
++++ b/zebra/zebra_evpn_mh.c
+@@ -1618,6 +1618,10 @@ static struct zebra_evpn_es_vtep *zebra_evpn_es_vtep_find(
+ static bool zebra_evpn_es_br_port_dplane_clear(struct zebra_evpn_es *es)
+ {
+ 	struct in_addr sph_filters[ES_VTEP_MAX_CNT];
++	vlanid_t vlans[DPLANE_BR_PORT_MAX_VLANS];
++	uint32_t vlan_cnt = 0;
++	struct zebra_evpn_es_evi *es_evi;
++	struct listnode *node;
+ 
+ 	if (!(es->flags & ZEBRA_EVPNES_BR_PORT))
+ 		return false;
+@@ -1625,9 +1629,22 @@ static bool zebra_evpn_es_br_port_dplane_clear(struct zebra_evpn_es *es)
+ 	if (IS_ZEBRA_DEBUG_EVPN_MH_ES)
+ 		zlog_debug("es %s br-port dplane clear", es->esi_str);
+ 
++	/* Collect VLANs so per-VLAN DEL messages can be generated
++	 * by the FPM encoder. Must be called while es_evi_list still
++	 * has entries.
++	 */
++	for (ALL_LIST_ELEMENTS_RO(es->es_evi_list, node, es_evi)) {
++		if (!(es_evi->flags & ZEBRA_EVPNES_EVI_LOCAL))
++			continue;
++		if (es_evi->zevpn && es_evi->zevpn->vid) {
++			if (vlan_cnt < DPLANE_BR_PORT_MAX_VLANS)
++				vlans[vlan_cnt++] = es_evi->zevpn->vid;
++		}
++	}
++
+ 	memset(&sph_filters, 0, sizeof(sph_filters));
+ 	dplane_br_port_update(es->zif->ifp, false /* non_df */, 0, sph_filters,
+-			      0 /* backup_nhg_id */);
++			      0 /* backup_nhg_id */, vlan_cnt, vlans);
+ 	return true;
+ }
+ 
+@@ -1648,6 +1665,9 @@ static bool zebra_evpn_es_br_port_dplane_update(struct zebra_evpn_es *es,
+ 	struct listnode *node = NULL;
+ 	struct zebra_evpn_es_vtep *es_vtep;
+ 	uint32_t sph_filter_cnt = 0;
++	vlanid_t vlans[DPLANE_BR_PORT_MAX_VLANS];
++	uint32_t vlan_cnt = 0;
++	struct zebra_evpn_es_evi *es_evi;
+ 
+ 	if (!(es->flags & ZEBRA_EVPNES_LOCAL))
+ 		return zebra_evpn_es_br_port_dplane_clear(es);
+@@ -1686,8 +1706,19 @@ static bool zebra_evpn_es_br_port_dplane_update(struct zebra_evpn_es *es,
+ 		}
+ 	}
+ 
++	/* Collect VLANs associated with this ES via the ES-EVI list */
++	for (ALL_LIST_ELEMENTS_RO(es->es_evi_list, node, es_evi)) {
++		if (!(es_evi->flags & ZEBRA_EVPNES_EVI_LOCAL))
++			continue;
++		if (es_evi->zevpn && es_evi->zevpn->vid) {
++			if (vlan_cnt < DPLANE_BR_PORT_MAX_VLANS)
++				vlans[vlan_cnt++] = es_evi->zevpn->vid;
++		}
++	}
++
+ 	dplane_br_port_update(es->zif->ifp, !!(es->flags & ZEBRA_EVPNES_NON_DF),
+-			      sph_filter_cnt, sph_filters, backup_nhg_id);
++			      sph_filter_cnt, sph_filters, backup_nhg_id,
++			      vlan_cnt, vlans);
+ 
+ 	return true;
+ }
+@@ -2390,6 +2421,16 @@ static void zebra_evpn_local_es_del(struct zebra_evpn_es **esp)
+ 			   es->nhg_id, zif ? zif->ifp->name : "-");
+ 	}
+ 
++	/* Flush BR port dplane state (SHL/DF/NHG) BEFORE removing ES-EVIs
++	 * so per-VLAN DEL messages can be generated for current VLANs.
++	 * Clear the BR_PORT flag to prevent duplicate dplane work in
++	 * zebra_evpn_es_local_info_clear().
++	 */
++	if (es->flags & ZEBRA_EVPNES_BR_PORT) {
++		zebra_evpn_es_br_port_dplane_clear(es);
++		es->flags &= ~ZEBRA_EVPNES_BR_PORT;
++	}
++
+ 	/* remove all ES-EVIs associated with the ES */
+ 	for (ALL_LIST_ELEMENTS(es->es_evi_list, node, nnode, es_evi))
+ 		zebra_evpn_local_es_evi_do_del(es_evi);
