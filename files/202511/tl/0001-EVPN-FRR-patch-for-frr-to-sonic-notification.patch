@@ -0,0 +1,181 @@
+diff --git a/zebra/zebra_dplane.c b/zebra/zebra_dplane.c
+index 9c252cc63..7195e91bd 100644
+--- a/zebra/zebra_dplane.c
++++ b/zebra/zebra_dplane.c
+@@ -189,6 +189,8 @@ struct dplane_br_port_info {
+ 	/* DPLANE_BR_PORT_XXX - see zebra_dplane.h*/
+ 	uint32_t flags;
+ 	uint32_t backup_nhg_id;
++	uint32_t vlan_cnt;
++	vlanid_t vlans[DPLANE_BR_PORT_MAX_VLANS];
+ };
+ 
+ /*
+@@ -3165,6 +3167,22 @@ dplane_ctx_get_br_port_backup_nhg_id(const struct zebra_dplane_ctx *ctx)
+ 	return ctx->u.br_port.backup_nhg_id;
+ }
