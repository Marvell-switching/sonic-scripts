 };
 
+/*
+ * EVPN Multihoming FPM message types and structures.
+ * These match the definitions in sonic-swss fpmsyncd/fpm/fpm.h
+ */
+enum fpm_evpn_msg_types {
+	RTM_FPM_FIRST			= 140,
+	RTM_FPM_ADD_EVPN_SHL		= 143,
+	RTM_FPM_DEL_EVPN_SHL		= 144,
+	RTM_FPM_ADD_EVPN_DF		= 145,
+	RTM_FPM_DEL_EVPN_DF		= 146,
+	RTM_FPM_ADD_EVPN_ES_BACKUP_NHG	= 147,
+	RTM_FPM_DEL_EVPN_ES_BACKUP_NHG	= 148,
+};
+
+struct fpm_evpn_shl_msg {
+	int esm_ifindex;
+	uint16_t esm_vid;
+};
+
+struct fpm_evpn_df_msg {
+	int edm_ifindex;
+	uint16_t edm_vid;
+	int edm_non_df;
+};
+
+struct fpm_evpn_backup_nhg_msg {
+	int ebnm_ifindex;
+	int ebnm_backup_nhg_id;
+};
+
+/* Attribute types for SHL VTEP IP addresses */
+#define FPM_EVPN_SHL_IPV4_ADDR	1
+#define FPM_EVPN_SHL_IPV6_ADDR	2
+
 static const char *prov_name = "dplane_fpm_sonic";
 
 static atomic_bool fpm_cleaning_up;
@@ -2439,6 +2473,169 @@ static ssize_t netlink_sidlist_msg_encode(int cmd,
 	return NLMSG_ALIGN(req->n.nlmsg_len);
 }
 
+/*
+ * Encode EVPN multihoming BR_PORT_UPDATE into FPM netlink messages.
+ *
+ * A single BR_PORT_UPDATE dplane context is expanded into multiple FPM
+ * messages:
+ *   - One RTM_FPM_ADD/DEL_EVPN_SHL per VLAN (with VTEP IP attributes)
+ *   - One RTM_FPM_ADD/DEL_EVPN_DF per VLAN
+ *   - One RTM_FPM_ADD/DEL_EVPN_ES_BACKUP_NHG for the port
+ *
+ * Returns total bytes written to nl_buf, or 0 if nothing to encode.
+ */
+static ssize_t
+fpm_nl_encode_evpn_br_port(struct zebra_dplane_ctx *ctx,
+			   uint8_t *nl_buf, size_t buf_size)
+{
+	ifindex_t ifindex = dplane_ctx_get_ifindex(ctx);
+	uint32_t flags = dplane_ctx_get_br_port_flags(ctx);
+	uint32_t sph_filter_cnt = dplane_ctx_get_br_port_sph_filter_cnt(ctx);
+	const struct in_addr *sph_filters = dplane_ctx_get_br_port_sph_filters(ctx);
+	uint32_t backup_nhg_id = dplane_ctx_get_br_port_backup_nhg_id(ctx);
+	uint32_t vlan_cnt = dplane_ctx_get_br_port_vlan_cnt(ctx);
+	const vlanid_t *vlans = dplane_ctx_get_br_port_vlans(ctx);
+	bool non_df = !!(flags & DPLANE_BR_PORT_NON_DF);
+	bool is_clear = (sph_filter_cnt == 0 && backup_nhg_id == 0
+			 && !non_df);
+	size_t offset = 0;
+	uint32_t i;
+
+	if (IS_ZEBRA_DEBUG_FPM)
+		zlog_debug("%s: ifindex %u flags 0x%x sph_cnt %u nhg 0x%x vlans %u %s",
+			   __func__, ifindex, flags, sph_filter_cnt,
+			   backup_nhg_id, vlan_cnt,
+			   is_clear ? "(clear)" : "");
+
+	/*
+	 * Encode SHL messages - one per VLAN.
+	 * Each message: nlmsghdr + fpm_evpn_shl_msg + rtattr per VTEP IP
+	 */
+	for (i = 0; i < vlan_cnt; i++) {
+		struct nlmsghdr *nlh;
+		struct fpm_evpn_shl_msg *shl;
+		uint16_t shl_type;
+		size_t msg_len;
+		uint32_t j;
+
+		shl_type = is_clear ? RTM_FPM_DEL_EVPN_SHL
+				    : RTM_FPM_ADD_EVPN_SHL;
+
+		/* Calculate message size: nlmsghdr + shl_msg + rtattrs */
+		msg_len = NLMSG_ALIGN(NLMSG_LENGTH(sizeof(*shl)));
+		if (!is_clear) {
+			for (j = 0; j < sph_filter_cnt; j++)
+				msg_len += RTA_SPACE(sizeof(struct in_addr));
+		}
+
+		if (offset + msg_len > buf_size) {
+			zlog_warn("%s: buffer full encoding SHL vlan %u",
+				  __func__, vlans[i]);
+			break;
+		}
+
+		nlh = (struct nlmsghdr *)(nl_buf + offset);
+		memset(nlh, 0, msg_len);
+		nlh->nlmsg_len = (uint32_t)msg_len;
+		nlh->nlmsg_type = shl_type;
+		nlh->nlmsg_flags = 0;
+
+		shl = (struct fpm_evpn_shl_msg *)NLMSG_DATA(nlh);
+		shl->esm_ifindex = (int)ifindex;
+		shl->esm_vid = vlans[i];
+
+		/* Append VTEP IP attributes for ADD messages */
+		if (!is_clear && sph_filter_cnt > 0) {
+			struct rtattr *rta;
+
+			rta = (struct rtattr *)((char *)shl
+				+ NLMSG_ALIGN(sizeof(*shl)));
+			for (j = 0; j < sph_filter_cnt; j++) {
+				rta->rta_type = FPM_EVPN_SHL_IPV4_ADDR;
+				rta->rta_len = RTA_LENGTH(sizeof(struct in_addr));
+				memcpy(RTA_DATA(rta), &sph_filters[j],
+				       sizeof(struct in_addr));
+				rta = (struct rtattr *)((char *)rta
+					+ RTA_SPACE(sizeof(struct in_addr)));
+			}
+		}
+
+		offset += NLMSG_ALIGN(msg_len);
+	}
+
+	/*
+	 * Encode DF messages - one per VLAN.
+	 * Each message: nlmsghdr + fpm_evpn_df_msg
+	 */
+	for (i = 0; i < vlan_cnt; i++) {
+		struct nlmsghdr *nlh;
+		struct fpm_evpn_df_msg *df;
+		uint16_t df_type;
+		size_t msg_len;
+
+		df_type = is_clear ? RTM_FPM_DEL_EVPN_DF
+				   : RTM_FPM_ADD_EVPN_DF;
+
+		msg_len = NLMSG_ALIGN(NLMSG_LENGTH(sizeof(*df)));
+
+		if (offset + msg_len > buf_size) {
+			zlog_warn("%s: buffer full encoding DF vlan %u",
+				  __func__, vlans[i]);
+			break;
+		}
+
+		nlh = (struct nlmsghdr *)(nl_buf + offset);
+		memset(nlh, 0, msg_len);
+		nlh->nlmsg_len = (uint32_t)msg_len;
+		nlh->nlmsg_type = df_type;
+		nlh->nlmsg_flags = 0;
+
+		df = (struct fpm_evpn_df_msg *)NLMSG_DATA(nlh);
+		df->edm_ifindex = (int)ifindex;
+		df->edm_vid = vlans[i];
+		df->edm_non_df = non_df ? 1 : 0;
+
+		offset += NLMSG_ALIGN(msg_len);
+	}
+
+	/*
+	 * Encode Backup NHG message - one per port (not per-VLAN).
+	 * nlmsghdr + fpm_evpn_backup_nhg_msg
+	 */
+	{
+		struct nlmsghdr *nlh;
+		struct fpm_evpn_backup_nhg_msg *nhg;
+		uint16_t nhg_type;
+		size_t msg_len;
+
+		nhg_type = is_clear ? RTM_FPM_DEL_EVPN_ES_BACKUP_NHG
+				    : RTM_FPM_ADD_EVPN_ES_BACKUP_NHG;
+
+		msg_len = NLMSG_ALIGN(NLMSG_LENGTH(sizeof(*nhg)));
+
+		if (offset + msg_len > buf_size) {
+			zlog_warn("%s: buffer full encoding backup NHG",
+				  __func__);
+			goto done;
+		}
+
+		nlh = (struct nlmsghdr *)(nl_buf + offset);
+		memset(nlh, 0, msg_len);
+		nlh->nlmsg_len = (uint32_t)msg_len;
+		nlh->nlmsg_type = nhg_type;
+		nlh->nlmsg_flags = 0;
+
+		nhg = (struct fpm_evpn_backup_nhg_msg *)NLMSG_DATA(nlh);
+		nhg->ebnm_ifindex = (int)ifindex;
+		nhg->ebnm_backup_nhg_id = (int)backup_nhg_id;
+
+		offset += NLMSG_ALIGN(msg_len);
+	}
+
+done:
+	return (ssize_t)offset;
+}
+
 #define DPLANE_FPM_NL_BUF_SIZE 65536
 /**
  * Encode data plane operation context into netlink and enqueue it in the FPM
@@ -2667,6 +2864,19 @@ static int fpm_nl_enqueue(struct fpm_nl_ctx *fnc, struct zebra_dplane_ctx *ctx)
 				 fnc, 0, &fnc->t_ribreset);
 		break;
 
+	case DPLANE_OP_BR_PORT_UPDATE:
+		rv = fpm_nl_encode_evpn_br_port(ctx, nl_buf, sizeof(nl_buf));
+		if (rv <= 0) {
+			if (IS_ZEBRA_DEBUG_FPM)
+				zlog_debug(
+					"%s: fpm_nl_encode_evpn_br_port: nothing to encode",
+					__func__);
+			return 0;
+		}
+
+		nl_buf_len = (size_t)rv;
+		break;
+
 	/* Un-handled by FPM at this time. */
 	case DPLANE_OP_PW_INSTALL:
 	case DPLANE_OP_PW_UNINSTALL:
@@ -2683,7 +2893,6 @@ static int fpm_nl_enqueue(struct fpm_nl_ctx *fnc, struct zebra_dplane_ctx *ctx)
 	case DPLANE_OP_RULE_DELETE:
 	case DPLANE_OP_RULE_UPDATE:
 	case DPLANE_OP_NEIGH_DISCOVER:
-	case DPLANE_OP_BR_PORT_UPDATE:
 	case DPLANE_OP_IPTABLE_ADD:
 	case DPLANE_OP_IPTABLE_DELETE:
 	case DPLANE_OP_IPSET_ADD:
diff --git a/src/sonic-frr/patch/evpn-mh-frr-zebra.patch b/src/sonic-frr/patch/evpn-mh-frr-zebra.patch
new file mode 100644
