+ 		if (nexthop->weight)
+@@ -2320,11 +2348,16 @@ static bool _netlink_route_build_multipath(const struct prefix *p,
+ 		else if (nexthop->src.ipv4.s_addr != INADDR_ANY)
+ 			*src = &nexthop->src;
