++    1. Check the DF role on all the PEs on rack-1.
++    2. Increase the DF preference on the non-DF and check if it becomes
++       the DF winner.
++    """
++
++    tgen = get_topogen()
++
++    if tgen.routers_have_failure():
++        pytest.skip(tgen.errors)
