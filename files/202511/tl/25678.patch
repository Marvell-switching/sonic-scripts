++                #     join-prune-interval 5
++                # - interface <uplinks> ipv6 pim
++                # - interface ipmr-lo ipv6 pim
++                uplinks = {
++                    "torm11": ["torm11-eth0", "torm11-eth1"],
++                    "torm12": ["torm12-eth0", "torm12-eth1"],
++                    "torm21": ["torm21-eth0", "torm21-eth1"],
++                    "torm22": ["torm22-eth0", "torm22-eth1"],
