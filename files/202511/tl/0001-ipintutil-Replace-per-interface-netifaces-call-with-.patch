 from unittest import mock
 
 from sonic_py_common import multi_asic
@@ -86,9 +88,49 @@ def mock_multi_asic_get_ip_intf_addr_from_ns(namespace, iface):
     return ipaddresses
 
 
+def _netifaces_to_ip_json(namespace):
+    """Convert mock_intf_table[namespace] from netifaces format to ip -json addr show format."""
+    result = {}
+    for ifname, af_dict in mock_intf_table.get(namespace, {}).items():
+        addr_info = []
+        for af, addrs in af_dict.items():
+            if af == netifaces.AF_INET:
+                for a in addrs:
+                    try:
+                        pl = _ipaddress.IPv4Network('0.0.0.0/' + a['netmask'], strict=False).prefixlen
+                    except Exception:
+                        pl = 32
+                    addr_info.append({'family': 'inet', 'local': a['addr'], 'prefixlen': pl})
+            elif af == netifaces.AF_INET6:
+                for a in addrs:
+                    nm = a['netmask']
+                    if '/' in nm:
+                        pl = int(nm.split('/')[-1])
+                    else:
+                        try:
+                            pl = _ipaddress.IPv6Network('::/' + nm, strict=False).prefixlen
+                        except Exception:
+                            pl = 64
+                    raw_addr = a['addr']
+                    local_addr = raw_addr.split('%')[0]
+                    entry = {'family': 'inet6', 'local': local_addr, 'prefixlen': pl}
+                    if '%' in raw_addr:
+                        entry['scope'] = 'link'
+                    addr_info.append(entry)
+        result[ifname] = {'ifname': ifname, 'addr_info': addr_info}
+    return result
+
+
+def mock_multi_asic_get_addr_info_from_ns(namespace):
+    return _netifaces_to_ip_json(namespace)
+
+
 multi_asic.get_num_asics = mock_get_num_asics
 multi_asic.is_multi_asic = mock_is_multi_asic
 multi_asic.get_namespace_list = mock_get_namespace_list
 multi_asic.get_namespaces_from_linux = mock_get_namespace_list
 multi_asic_util.multi_asic_get_ip_intf_from_ns = mock_multi_asic_get_ip_intf_from_ns
 multi_asic_util.multi_asic_get_ip_intf_addr_from_ns = mock_multi_asic_get_ip_intf_addr_from_ns
+multi_asic_util.multi_asic_get_addr_info_from_ns = mock_multi_asic_get_addr_info_from_ns
+multi_asic_util.get_if_admin_state = lambda iface, namespace: "error"
+multi_asic_util.get_if_oper_state = lambda iface, namespace: "down"
