+            elif table == 'BFD_PEER':
+                # Parse BFD_PEER key: prefix contains remote_addr, key contains local_addr|interface|hop_type
+                remote_addr = prefix
+                key_params = key.split('|') if key else []
+                if len(key_params) >= 2:
+                    local_addr = key_params[0] if key_params[0] != 'null' else None
+                    interface = key_params[1] if key_params[1] != 'null' else None
+                    hop_type = key_params[2] if len(key_params) > 2 else 'singlehop'
